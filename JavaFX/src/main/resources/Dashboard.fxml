<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.chart.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="Controller.DashboardController"
      spacing="16" style="-fx-background-color: transparent;">

    <!-- ══ BARRE TITRE ══ -->
    <HBox alignment="CENTER_LEFT" spacing="10">
        <VBox spacing="3">
            <Label text="Vue d'ensemble"
                   style="-fx-font-size:22px;-fx-font-weight:bold;-fx-text-fill:#1e293b;"/>
            <Label fx:id="lblDate" text="Aujourd'hui"
                   style="-fx-font-size:13px;-fx-text-fill:#94a3b8;"/>
        </VBox>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="⟳  Actualiser" onAction="#handleRefresh"
                style="-fx-background-color:white;-fx-text-fill:#1e293b;-fx-font-size:13px;
                       -fx-font-weight:bold;-fx-background-radius:10px;-fx-cursor:hand;
                       -fx-padding:10 20;-fx-border-color:#e5e9f0;-fx-border-width:1.5px;
                       -fx-border-radius:10px;"/>
        <Button text="Telecharger Excel" onAction="#handleExportExcel"
                style="-fx-background-color:#16a34a;-fx-text-fill:white;-fx-font-size:13px;
                       -fx-font-weight:bold;-fx-background-radius:10px;-fx-cursor:hand;
                       -fx-padding:10 20;"/>
    </HBox>

    <!-- ══ STAT CARDS ══ -->
    <HBox spacing="12">

        <VBox spacing="0" HBox.hgrow="ALWAYS"
              style="-fx-background-color:white;-fx-background-radius:14px;
                     -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.07),8,0,0,2);">
            <Region style="-fx-background-color:#1e3a5f;-fx-background-radius:14 14 0 0;-fx-pref-height:4px;"/>
            <VBox spacing="8" style="-fx-padding:14 16;">
                <Label text="👥  Utilisateurs" style="-fx-font-size:11px;-fx-text-fill:#64748b;"/>
                <Label fx:id="lblTotalUsers" text="—"
                       style="-fx-font-size:26px;-fx-font-weight:bold;-fx-text-fill:#1e293b;"/>
                <Label text="Total enregistrés" style="-fx-font-size:9px;-fx-text-fill:#94a3b8;"/>
            </VBox>
        </VBox>

        <VBox spacing="0" HBox.hgrow="ALWAYS"
              style="-fx-background-color:white;-fx-background-radius:14px;
                     -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.07),8,0,0,2);">
            <Region style="-fx-background-color:#c2410c;-fx-background-radius:14 14 0 0;-fx-pref-height:4px;"/>
            <VBox spacing="8" style="-fx-padding:14 16;">
                <Label text="🏭  Fournisseurs" style="-fx-font-size:11px;-fx-text-fill:#64748b;"/>
                <Label fx:id="lblTotalFournisseurs" text="—"
                       style="-fx-font-size:26px;-fx-font-weight:bold;-fx-text-fill:#c2410c;"/>
                <Label text="Inscrits" style="-fx-font-size:9px;-fx-text-fill:#94a3b8;"/>
            </VBox>
        </VBox>

        <VBox spacing="0" HBox.hgrow="ALWAYS"
              style="-fx-background-color:white;-fx-background-radius:14px;
                     -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.07),8,0,0,2);">
            <Region style="-fx-background-color:#166534;-fx-background-radius:14 14 0 0;-fx-pref-height:4px;"/>
            <VBox spacing="8" style="-fx-padding:14 16;">
                <Label text="💼  Entrepreneurs" style="-fx-font-size:11px;-fx-text-fill:#64748b;"/>
                <Label fx:id="lblTotalEntrepreneurs" text="—"
                       style="-fx-font-size:26px;-fx-font-weight:bold;-fx-text-fill:#166534;"/>
                <Label text="Inscrits" style="-fx-font-size:9px;-fx-text-fill:#94a3b8;"/>
            </VBox>
        </VBox>

        <VBox spacing="0" HBox.hgrow="ALWAYS"
              style="-fx-background-color:white;-fx-background-radius:14px;
                     -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.07),8,0,0,2);">
            <Region style="-fx-background-color:#f97316;-fx-background-radius:14 14 0 0;-fx-pref-height:4px;"/>
            <VBox spacing="8" style="-fx-padding:14 16;">
                <Label text="📦  Produits" style="-fx-font-size:11px;-fx-text-fill:#64748b;"/>
                <Label fx:id="lblTotalProduits" text="—"
                       style="-fx-font-size:26px;-fx-font-weight:bold;-fx-text-fill:#1e293b;"/>
                <Label text="En catalogue" style="-fx-font-size:9px;-fx-text-fill:#94a3b8;"/>
            </VBox>
        </VBox>

        <VBox spacing="0" HBox.hgrow="ALWAYS"
              style="-fx-background-color:white;-fx-background-radius:14px;
                     -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.07),8,0,0,2);">
            <Region style="-fx-background-color:#10b981;-fx-background-radius:14 14 0 0;-fx-pref-height:4px;"/>
            <VBox spacing="8" style="-fx-padding:14 16;">
                <Label text="🛍️  Commandes" style="-fx-font-size:11px;-fx-text-fill:#64748b;"/>
                <Label fx:id="lblTotalCommandes" text="—"
                       style="-fx-font-size:26px;-fx-font-weight:bold;-fx-text-fill:#1e293b;"/>
                <Label text="Ce mois" style="-fx-font-size:9px;-fx-text-fill:#94a3b8;"/>
            </VBox>
        </VBox>

        <VBox spacing="0" HBox.hgrow="ALWAYS"
              style="-fx-background-color:white;-fx-background-radius:14px;
                     -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.07),8,0,0,2);">
            <Region style="-fx-background-color:#8b5cf6;-fx-background-radius:14 14 0 0;-fx-pref-height:4px;"/>
            <VBox spacing="8" style="-fx-padding:14 16;">
                <Label text="💬  Feedbacks" style="-fx-font-size:11px;-fx-text-fill:#64748b;"/>
                <Label fx:id="lblTotalFeedbacks" text="—"
                       style="-fx-font-size:26px;-fx-font-weight:bold;-fx-text-fill:#1e293b;"/>
                <Label text="Total reçus" style="-fx-font-size:9px;-fx-text-fill:#94a3b8;"/>
            </VBox>
        </VBox>

    </HBox>

    <!-- ══ GRAPHIQUES ══ -->
    <HBox spacing="14" VBox.vgrow="ALWAYS">

        <!-- PieChart -->
        <VBox HBox.hgrow="ALWAYS"
              style="-fx-background-color:white;-fx-background-radius:14px;
                     -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.07),8,0,0,2);-fx-padding:14;">
            <HBox alignment="CENTER_LEFT" spacing="6" style="-fx-padding:0 0 8 0;">
                <Label text="●" style="-fx-text-fill:#f97316;-fx-font-size:10px;"/>
                <Label text="Répartition par rôle"
                       style="-fx-font-size:13px;-fx-font-weight:bold;-fx-text-fill:#1e293b;"/>
            </HBox>
            <PieChart fx:id="pieChartRoles" VBox.vgrow="ALWAYS"
                      labelsVisible="true" legendVisible="true"
                      style="-fx-background-color:transparent;" prefHeight="200"/>
        </VBox>

        <!-- BarChart -->
        <VBox HBox.hgrow="ALWAYS"
              style="-fx-background-color:white;-fx-background-radius:14px;
                     -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.07),8,0,0,2);-fx-padding:14;">
            <HBox alignment="CENTER_LEFT" spacing="6" style="-fx-padding:0 0 8 0;">
                <Label text="●" style="-fx-text-fill:#1e3a5f;-fx-font-size:10px;"/>
                <Label text="Utilisateurs par rôle"
                       style="-fx-font-size:13px;-fx-font-weight:bold;-fx-text-fill:#1e293b;"/>
            </HBox>
            <BarChart fx:id="barChartUsers" VBox.vgrow="ALWAYS"
                      style="-fx-background-color:transparent;"
                      animated="true" legendVisible="false" prefHeight="200">
                <xAxis><CategoryAxis fx:id="barXAxis" label="Rôle"/></xAxis>
                <yAxis><NumberAxis fx:id="barYAxis" label="Nombre" minorTickVisible="false"/></yAxis>
            </BarChart>
        </VBox>

    </HBox>

    <!-- ══ TABLEAU RÉCENTS ══ -->
    <VBox spacing="0" VBox.vgrow="ALWAYS"
          style="-fx-background-color:white;-fx-background-radius:14px;
                 -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.07),8,0,0,2);">

        <HBox alignment="CENTER_LEFT" style="-fx-padding:14 18 10 18;">
            <VBox spacing="2">
                <Label text="Utilisateurs récents"
                       style="-fx-font-size:13px;-fx-font-weight:bold;-fx-text-fill:#1e293b;"/>
                <Label text="Derniers comptes créés"
                       style="-fx-font-size:10px;-fx-text-fill:#94a3b8;"/>
            </VBox>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="Voir tous →" onAction="#handleViewAllUsers"
                    style="-fx-background-color:#fff7ed;-fx-text-fill:#f97316;-fx-font-size:12px;
                           -fx-font-weight:bold;-fx-background-radius:8px;-fx-padding:7 14;
                           -fx-cursor:hand;"/>
        </HBox>

        <Region style="-fx-background-color:#f1f5f9;-fx-pref-height:1px;"/>

        <TableView fx:id="recentUsersTable" VBox.vgrow="ALWAYS"
                   style="-fx-background-color:transparent;-fx-border-color:transparent;
                          -fx-table-cell-border-color:#f1f5f9;-fx-font-size:13px;">
            <columns>
                <TableColumn fx:id="colId"         text="#"              prefWidth="50"  style="-fx-alignment:CENTER;"/>
                <TableColumn fx:id="colNomComplet" text="Nom complet"    prefWidth="180"/>
                <TableColumn fx:id="colEmail"      text="Email"          prefWidth="210"/>
                <TableColumn fx:id="colRole"       text="Rôle"           prefWidth="130" style="-fx-alignment:CENTER;"/>
                <TableColumn fx:id="colDDN"        text="Date naissance" prefWidth="140" style="-fx-alignment:CENTER;"/>
            </columns>
            <placeholder>
                <Label text="Aucun utilisateur trouvé"
                       style="-fx-text-fill:#94a3b8;-fx-font-size:14px;"/>
            </placeholder>
        </TableView>
    </VBox>

</VBox>
