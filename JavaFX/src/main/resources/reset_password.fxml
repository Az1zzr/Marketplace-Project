<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.shape.*?>
<?import javafx.geometry.Insets?>

<StackPane xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="Controller.ResetPasswordController"
           alignment="CENTER"
           style="-fx-background-color: #060d1a;">

    <!-- ══ Arrière-plan décoratif ══ -->
    <Circle radius="380" fill="rgba(249,115,22,0.035)"
            StackPane.alignment="TOP_RIGHT" translateX="160" translateY="-140"/>
    <Circle radius="260" fill="rgba(30,58,95,0.4)"
            StackPane.alignment="BOTTOM_LEFT" translateX="-100" translateY="100"/>
    <Circle radius="140" fill="rgba(249,115,22,0.05)"
            StackPane.alignment="BOTTOM_RIGHT" translateX="80" translateY="80"/>
    <Circle radius="80" fill="rgba(16,185,129,0.04)"
            StackPane.alignment="TOP_LEFT" translateX="-20" translateY="60"/>

    <!-- ══ Carte centrée ══ -->
    <VBox spacing="0" maxWidth="480" minWidth="440"
          style="-fx-background-color: #ffffff;
                 -fx-background-radius: 24px;
                 -fx-border-color: #e2e8f0;
                 -fx-border-width: 1.5px;
                 -fx-border-radius: 24px;
                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.65), 48, 0, 0, 20);">

        <!-- ── Header ── -->
        <VBox alignment="CENTER" spacing="10"
              style="-fx-padding: 36 36 28 36;
                     -fx-background-color: #f8fafc;
                     -fx-background-radius: 24 24 0 0;">

            <StackPane maxWidth="72" maxHeight="72">
                <Circle radius="36" fill="rgba(16,185,129,0.12)" stroke="rgba(16,185,129,0.3)" strokeWidth="1.5"/>
                <Label text="🔐" style="-fx-font-size: 30px;"/>
            </StackPane>

            <Label text="Nouveau mot de passe"
                   style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
            <Label text="Choisissez un mot de passe fort et sécurisé"
                   wrapText="true" textAlignment="CENTER"
                   style="-fx-font-size: 12px; -fx-text-fill: #64748b; -fx-text-alignment: center;"/>
        </VBox>

        <!-- Barre verte accent -->
        <Region style="-fx-background-color: #10b981; -fx-pref-height: 3px;"/>

        <!-- ── Contenu ── -->
        <VBox spacing="20" style="-fx-padding: 32 36 36 36;">

            <!-- Feedback -->
            <Label fx:id="feedbackLabel" wrapText="true" managed="false" visible="false"
                   style="-fx-font-size: 12px; -fx-background-radius: 10px; -fx-border-radius: 10px;
                          -fx-padding: 12 16; -fx-border-width: 1px;"/>

            <!-- Règles -->
            <HBox spacing="8" alignment="CENTER_LEFT"
                  style="-fx-background-color: #f0fdf4; -fx-background-radius: 10px;
                         -fx-border-color: #bbf7d0; -fx-border-width: 1px; -fx-border-radius: 10px;
                         -fx-padding: 10 14;">
                <Label text="✅" style="-fx-font-size: 12px;"/>
                <Label text="Minimum 8 caractères  ·  1 majuscule  ·  1 chiffre"
                       style="-fx-font-size: 11px; -fx-text-fill: #166534;"/>
            </HBox>

            <!-- Nouveau mot de passe -->
            <VBox spacing="8">
                <Label text="Nouveau mot de passe"
                       style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #374151;
                              -fx-padding: 0 0 0 2;"/>
                <StackPane>
                    <HBox alignment="CENTER_LEFT"
                          style="-fx-background-color: #f9fafb; -fx-background-radius: 12px;
                                 -fx-border-color: #d1d5db; -fx-border-width: 1.5px;
                                 -fx-border-radius: 12px;">
                        <Label text="  🔒  "
                               style="-fx-font-size: 15px; -fx-text-fill: #9ca3af; -fx-padding: 0 2;"/>
                        <PasswordField fx:id="passwordField" promptText="••••••••"
                                       HBox.hgrow="ALWAYS"
                                       style="-fx-pref-height: 50px; -fx-background-color: transparent;
                                              -fx-border-color: transparent; -fx-font-size: 14px;
                                              -fx-text-fill: #1e293b; -fx-prompt-text-fill: #9ca3af;
                                              -fx-padding: 12 48 12 4;"/>
                        <TextField fx:id="visiblePasswordField" promptText="••••••••"
                                   visible="false" managed="false"
                                   HBox.hgrow="ALWAYS"
                                   style="-fx-pref-height: 50px; -fx-background-color: transparent;
                                          -fx-border-color: transparent; -fx-font-size: 14px;
                                          -fx-text-fill: #1e293b; -fx-prompt-text-fill: #9ca3af;
                                          -fx-padding: 12 48 12 4;"/>
                    </HBox>
                    <Button fx:id="togglePwdBtn" text="👁️" onAction="#togglePassword"
                            style="-fx-background-color: transparent; -fx-cursor: hand;
                                   -fx-font-size: 15px; -fx-padding: 6 10;"
                            StackPane.alignment="CENTER_RIGHT">
                        <StackPane.margin><Insets right="6"/></StackPane.margin>
                    </Button>
                </StackPane>
            </VBox>

            <!-- Confirmer mot de passe -->
            <VBox spacing="8">
                <Label text="Confirmer le mot de passe"
                       style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #374151;
                              -fx-padding: 0 0 0 2;"/>
                <StackPane>
                    <HBox alignment="CENTER_LEFT"
                          style="-fx-background-color: #f9fafb; -fx-background-radius: 12px;
                                 -fx-border-color: #d1d5db; -fx-border-width: 1.5px;
                                 -fx-border-radius: 12px;">
                        <Label text="  🔒  "
                               style="-fx-font-size: 15px; -fx-text-fill: #9ca3af; -fx-padding: 0 2;"/>
                        <PasswordField fx:id="confirmField" promptText="••••••••"
                                       HBox.hgrow="ALWAYS"
                                       style="-fx-pref-height: 50px; -fx-background-color: transparent;
                                              -fx-border-color: transparent; -fx-font-size: 14px;
                                              -fx-text-fill: #1e293b; -fx-prompt-text-fill: #9ca3af;
                                              -fx-padding: 12 48 12 4;"/>
                        <TextField fx:id="visibleConfirmField" promptText="••••••••"
                                   visible="false" managed="false"
                                   HBox.hgrow="ALWAYS"
                                   style="-fx-pref-height: 50px; -fx-background-color: transparent;
                                          -fx-border-color: transparent; -fx-font-size: 14px;
                                          -fx-text-fill: #1e293b; -fx-prompt-text-fill: #9ca3af;
                                          -fx-padding: 12 48 12 4;"/>
                    </HBox>
                    <Button fx:id="toggleConfirmBtn" text="👁️" onAction="#toggleConfirm"
                            style="-fx-background-color: transparent; -fx-cursor: hand;
                                   -fx-font-size: 15px; -fx-padding: 6 10;"
                            StackPane.alignment="CENTER_RIGHT">
                        <StackPane.margin><Insets right="6"/></StackPane.margin>
                    </Button>
                </StackPane>
            </VBox>

            <!-- Bouton Réinitialiser -->
            <Button text="Réinitialiser le mot de passe  →" onAction="#handleResetPassword"
                    maxWidth="Infinity"
                    style="-fx-pref-height: 52px; -fx-font-size: 15px; -fx-font-weight: bold;
                           -fx-background-color: #10b981; -fx-text-fill: white;
                           -fx-background-radius: 13px; -fx-cursor: hand;
                           -fx-effect: dropshadow(gaussian, rgba(16,185,129,0.55), 18, 0, 0, 7);">
                <VBox.margin><Insets top="6"/></VBox.margin>
            </Button>

            <!-- Retour login -->
            <HBox alignment="CENTER">
                <Button text="← Retour à la connexion" onAction="#handleBackToLogin"
                        style="-fx-background-color: transparent; -fx-text-fill: #6b7280;
                               -fx-font-size: 12px; -fx-cursor: hand; -fx-padding: 0; -fx-underline: true;"/>
            </HBox>

        </VBox>
    </VBox>

</StackPane>
