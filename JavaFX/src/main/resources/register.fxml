<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.shape.*?>
<?import javafx.geometry.Insets?>

<StackPane xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="Controller.RegisterController"
           style="-fx-background-color: #060f1e;">

    <!-- Cercles décoratifs arrière-plan -->
    <Circle radius="300" fill="rgba(249,115,22,0.04)"
            StackPane.alignment="TOP_RIGHT" translateX="120" translateY="-80"/>
    <Circle radius="200" fill="rgba(30,58,95,0.35)"
            StackPane.alignment="BOTTOM_LEFT" translateX="-80" translateY="80"/>
    <Circle radius="120" fill="rgba(249,115,22,0.06)"
            StackPane.alignment="BOTTOM_RIGHT" translateX="60" translateY="60"/>

    <HBox>

        <!-- ══ PANNEAU GAUCHE : Branding ══ -->
        <VBox alignment="CENTER" spacing="32" prefWidth="460"
              style="-fx-padding: 60 48 60 60;">

            <ImageView fitWidth="210" fitHeight="105" preserveRatio="true" smooth="true">
                <image><Image url="@/images/logo_localtrade.png"/></image>
            </ImageView>

            <VBox spacing="10">
                <Label text="Bienvenue sur"
                       style="-fx-font-size: 14px; -fx-text-fill: #f97316; -fx-font-weight: bold;"/>
                <Label text="LocalTrade"
                       style="-fx-font-size: 38px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                <Label text="La marketplace qui connecte\nfournisseurs et entrepreneurs."
                       style="-fx-font-size: 14px; -fx-text-fill: #9ca3af;" wrapText="true"/>
            </VBox>

            <!-- Features -->
            <VBox spacing="18">
                <HBox alignment="CENTER_LEFT" spacing="16">
                    <StackPane minWidth="38" minHeight="38" maxWidth="38" maxHeight="38"
                               style="-fx-background-color: rgba(249,115,22,0.15); -fx-background-radius: 10px;">
                        <Label text="📦" style="-fx-font-size: 16px;"/>
                    </StackPane>
                    <VBox spacing="2">
                        <Label text="Gérez vos produits"
                               style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                        <Label text="Catalogue complet, prix et stock"
                               style="-fx-font-size: 11px; -fx-text-fill: #4a6080;"/>
                    </VBox>
                </HBox>
                <HBox alignment="CENTER_LEFT" spacing="16">
                    <StackPane minWidth="38" minHeight="38" maxWidth="38" maxHeight="38"
                               style="-fx-background-color: #f0fdf4; -fx-background-radius: 10px;">
                        <Label text="🛍️" style="-fx-font-size: 16px;"/>
                    </StackPane>
                    <VBox spacing="2">
                        <Label text="Commandes en temps réel"
                               style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                        <Label text="Suivi et gestion simplifiés"
                               style="-fx-font-size: 11px; -fx-text-fill: #4a6080;"/>
                    </VBox>
                </HBox>
                <HBox alignment="CENTER_LEFT" spacing="16">
                    <StackPane minWidth="38" minHeight="38" maxWidth="38" maxHeight="38"
                               style="-fx-background-color: rgba(139,92,246,0.12); -fx-background-radius: 10px;">
                        <Label text="💬" style="-fx-font-size: 16px;"/>
                    </StackPane>
                    <VBox spacing="2">
                        <Label text="Feedback et réputation"
                               style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                        <Label text="Avis clients et évaluations"
                               style="-fx-font-size: 11px; -fx-text-fill: #4a6080;"/>
                    </VBox>
                </HBox>
            </VBox>

            <!-- Séparateur + note bas -->
            <HBox alignment="CENTER_LEFT" spacing="10">
                <Region style="-fx-background-color: #1a2d47; -fx-pref-height: 1px;" HBox.hgrow="ALWAYS"/>
                <Label text="Sécurisé &amp; Fiable" style="-fx-font-size: 11px; -fx-text-fill: #2a4060;"/>
                <Region style="-fx-background-color: #1a2d47; -fx-pref-height: 1px;" HBox.hgrow="ALWAYS"/>
            </HBox>
        </VBox>

        <!-- ══ PANNEAU DROIT : Formulaire simplifié ══ -->
        <StackPane HBox.hgrow="ALWAYS" alignment="CENTER"
                   style="-fx-padding: 30 50 30 30;">

            <VBox spacing="0" maxWidth="400" alignment="CENTER"
                  style="-fx-background-color: #ffffff; -fx-background-radius: 24px;
                         -fx-border-color: #e2e8f0; -fx-border-width: 1.5px;
                         -fx-border-radius: 24px;
                         -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.6), 40, 0, 0, 16);">

                <!-- Header -->
                <VBox alignment="CENTER" spacing="6"
                      style="-fx-padding: 30 32 24 32; -fx-background-color: #f8fafc;
                             -fx-background-radius: 24 24 0 0;">
                    <Label text="Créer un compte"
                           style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
                    <Label text="Rejoignez LocalTrade gratuitement"
                           style="-fx-font-size: 12px; -fx-text-fill: #94a3b8;"/>
                    <Region style="-fx-background-color: #f97316; -fx-pref-height: 3px;
                                   -fx-pref-width: 50px; -fx-background-radius: 2px; -fx-padding-top: 6;"/>
                </VBox>

                <!-- Corps du formulaire -->
                <VBox spacing="18" style="-fx-padding: 28 32 32 32;">

                    <!-- Messages -->
                    <Label fx:id="errorLabel" wrapText="true" managed="false" visible="false"
                           style="-fx-text-fill: #dc2626; -fx-font-size: 12px;
                                  -fx-background-color: #fef2f2;
                                  -fx-border-color: #fecaca; -fx-border-width: 1px;
                                  -fx-background-radius: 10px; -fx-border-radius: 10px;
                                  -fx-padding: 12 16;"/>
                    <Label fx:id="successLabel" wrapText="true" managed="false" visible="false"
                           style="-fx-text-fill: #166534; -fx-font-size: 12px;
                                  -fx-background-color: #f0fdf4;
                                  -fx-border-color: #bbf7d0; -fx-border-width: 1px;
                                  -fx-background-radius: 10px; -fx-border-radius: 10px;
                                  -fx-padding: 12 16;"/>

                    <!-- Nom + Prénom -->
                    <HBox spacing="12">
                        <VBox spacing="7" HBox.hgrow="ALWAYS">
                            <Label text="Nom"
                                   style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #374151;"/>
                            <HBox alignment="CENTER_LEFT" spacing="0"
                                  style="-fx-background-color: #f9fafb; -fx-background-radius: 12px;
                                         -fx-border-color: #e2e8f0; -fx-border-width: 1.5px;
                                         -fx-border-radius: 12px;">
                                <Label text="  👤  "
                                       style="-fx-font-size: 13px; -fx-text-fill: #9ca3af; -fx-padding: 0 2;"/>
                                <TextField fx:id="nomField" promptText="Ben Ali"
                                           HBox.hgrow="ALWAYS"
                                           style="-fx-pref-height: 46px; -fx-background-color: transparent;
                                                  -fx-border-color: transparent; -fx-font-size: 13px;
                                                  -fx-text-fill: #1e293b; -fx-prompt-text-fill: #9ca3af;
                                                  -fx-padding: 12 10 12 4;"/>
                            </HBox>
                        </VBox>
                        <VBox spacing="7" HBox.hgrow="ALWAYS">
                            <Label text="Prénom"
                                   style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #374151;"/>
                            <HBox alignment="CENTER_LEFT" spacing="0"
                                  style="-fx-background-color: #f9fafb; -fx-background-radius: 12px;
                                         -fx-border-color: #e2e8f0; -fx-border-width: 1.5px;
                                         -fx-border-radius: 12px;">
                                <Label text="  👤  "
                                       style="-fx-font-size: 13px; -fx-text-fill: #9ca3af; -fx-padding: 0 2;"/>
                                <TextField fx:id="prenomField" promptText="Ahmed"
                                           HBox.hgrow="ALWAYS"
                                           style="-fx-pref-height: 46px; -fx-background-color: transparent;
                                                  -fx-border-color: transparent; -fx-font-size: 13px;
                                                  -fx-text-fill: #1e293b; -fx-prompt-text-fill: #9ca3af;
                                                  -fx-padding: 12 10 12 4;"/>
                            </HBox>
                        </VBox>
                    </HBox>

                    <!-- Email -->
                    <VBox spacing="7">
                        <Label text="Adresse email"
                               style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #374151;"/>
                        <HBox alignment="CENTER_LEFT" spacing="0"
                              style="-fx-background-color: #f9fafb; -fx-background-radius: 12px;
                                     -fx-border-color: #e2e8f0; -fx-border-width: 1.5px;
                                     -fx-border-radius: 12px;">
                            <Label text="  📧  "
                                   style="-fx-font-size: 14px; -fx-text-fill: #9ca3af; -fx-padding: 0 4;"/>
                            <TextField fx:id="emailField" promptText="vous@gmail.com"
                                       HBox.hgrow="ALWAYS"
                                       style="-fx-pref-height: 46px; -fx-background-color: transparent;
                                              -fx-border-color: transparent; -fx-font-size: 13px;
                                              -fx-text-fill: #1e293b; -fx-prompt-text-fill: #9ca3af;
                                              -fx-padding: 12 14 12 4;"/>
                        </HBox>
                    </VBox>


                    <!-- Téléphone -->
                    <VBox spacing="7">
                        <Label text="Numéro de téléphone"
                               style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #374151;"/>
                        <HBox alignment="CENTER_LEFT" spacing="0"
                              style="-fx-background-color: #f9fafb; -fx-background-radius: 12px;
                                     -fx-border-color: #e2e8f0; -fx-border-width: 1.5px;
                                     -fx-border-radius: 12px;">
                            <Label text="  📞  "
                                   style="-fx-font-size: 14px; -fx-text-fill: #9ca3af; -fx-padding: 0 4;"/>
                            <TextField fx:id="telephoneField" promptText="Ex: 20123456"
                                       HBox.hgrow="ALWAYS"
                                       style="-fx-pref-height: 46px; -fx-background-color: transparent;
                                              -fx-border-color: transparent; -fx-font-size: 13px;
                                              -fx-text-fill: #1e293b; -fx-prompt-text-fill: #9ca3af;
                                              -fx-padding: 12 14 12 4;"/>
                        </HBox>
                        <Label text="8 chiffres · commence par 2, 4, 5 ou 9"
                               style="-fx-font-size: 10px; -fx-text-fill: #9ca3af;"/>
                    </VBox>

                    <!-- Date de naissance -->
                    <VBox spacing="7">
                        <Label text="Date de naissance"
                               style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #374151;"/>
                        <HBox alignment="CENTER_LEFT" spacing="0"
                              style="-fx-background-color: #f9fafb; -fx-background-radius: 12px;
                                     -fx-border-color: #e2e8f0; -fx-border-width: 1.5px;
                                     -fx-border-radius: 12px; -fx-padding: 0 4;">
                            <Label text="  🎂  "
                                   style="-fx-font-size: 14px; -fx-text-fill: #9ca3af;"/>
                            <DatePicker fx:id="dateNaissancePicker"
                                        promptText="jj/mm/aaaa"
                                        HBox.hgrow="ALWAYS"
                                        style="-fx-pref-height: 46px; -fx-background-color: transparent;
                                               -fx-border-color: transparent; -fx-font-size: 13px;
                                               -fx-pref-width: 999px;"/>
                        </HBox>
                        <Label text="Minimum 16 ans requis"
                               style="-fx-font-size: 10px; -fx-text-fill: #9ca3af;"/>
                    </VBox>

                    <!-- Mot de passe -->
                    <VBox spacing="7">
                        <Label text="Mot de passe"
                               style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #374151;"/>
                        <StackPane>
                            <HBox alignment="CENTER_LEFT" spacing="0"
                                  style="-fx-background-color: #f9fafb; -fx-background-radius: 12px;
                                         -fx-border-color: #e2e8f0; -fx-border-width: 1.5px;
                                         -fx-border-radius: 12px;">
                                <Label text="  🔒  "
                                       style="-fx-font-size: 14px; -fx-text-fill: #9ca3af; -fx-padding: 0 4;"/>
                                <PasswordField fx:id="passwordField" promptText="Min. 8 car., 1 maj., 1 chiffre"
                                               HBox.hgrow="ALWAYS"
                                               style="-fx-pref-height: 46px; -fx-background-color: transparent;
                                                      -fx-border-color: transparent; -fx-font-size: 13px;
                                                      -fx-text-fill: #1e293b; -fx-prompt-text-fill: #9ca3af;
                                                      -fx-padding: 12 44 12 4;"/>
                                <TextField fx:id="visiblePasswordField" visible="false" managed="false"
                                           promptText="Min. 8 car., 1 maj., 1 chiffre"
                                           HBox.hgrow="ALWAYS"
                                           style="-fx-pref-height: 46px; -fx-background-color: transparent;
                                                  -fx-border-color: transparent; -fx-font-size: 13px;
                                                  -fx-text-fill: #1e293b; -fx-prompt-text-fill: #9ca3af;
                                                  -fx-padding: 12 44 12 4;"/>
                            </HBox>
                            <Button fx:id="togglePasswordButton" text="👁️" onAction="#togglePassword"
                                    style="-fx-background-color: transparent; -fx-cursor: hand;
                                           -fx-font-size: 14px; -fx-padding: 6 10;"
                                    StackPane.alignment="CENTER_RIGHT">
                                <StackPane.margin><Insets right="6"/></StackPane.margin>
                            </Button>
                        </StackPane>
                        <Label text="8 caractères minimum · 1 majuscule · 1 chiffre"
                               style="-fx-font-size: 10px; -fx-text-fill: #9ca3af;"/>
                    </VBox>

                    <!-- Confirmation mot de passe -->
                    <VBox spacing="7">
                        <Label text="Confirmer le mot de passe"
                               style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #374151;"/>
                        <StackPane>
                            <HBox alignment="CENTER_LEFT" spacing="0"
                                  style="-fx-background-color: #f9fafb; -fx-background-radius: 12px;
                                         -fx-border-color: #e2e8f0; -fx-border-width: 1.5px;
                                         -fx-border-radius: 12px;">
                                <Label text="  🔑  "
                                       style="-fx-font-size: 14px; -fx-text-fill: #9ca3af; -fx-padding: 0 4;"/>
                                <PasswordField fx:id="confirmPasswordField" promptText="Répétez votre mot de passe"
                                               HBox.hgrow="ALWAYS"
                                               style="-fx-pref-height: 46px; -fx-background-color: transparent;
                                                      -fx-border-color: transparent; -fx-font-size: 13px;
                                                      -fx-text-fill: #1e293b; -fx-prompt-text-fill: #9ca3af;
                                                      -fx-padding: 12 44 12 4;"/>
                                <TextField fx:id="visibleConfirmField" visible="false" managed="false"
                                           promptText="Répétez votre mot de passe"
                                           HBox.hgrow="ALWAYS"
                                           style="-fx-pref-height: 46px; -fx-background-color: transparent;
                                                  -fx-border-color: transparent; -fx-font-size: 13px;
                                                  -fx-text-fill: #1e293b; -fx-prompt-text-fill: #9ca3af;
                                                  -fx-padding: 12 44 12 4;"/>
                            </HBox>
                            <Button fx:id="toggleConfirmButton" text="👁️" onAction="#toggleConfirmPassword"
                                    style="-fx-background-color: transparent; -fx-cursor: hand;
                                           -fx-font-size: 14px; -fx-padding: 6 10;"
                                    StackPane.alignment="CENTER_RIGHT">
                                <StackPane.margin><Insets right="6"/></StackPane.margin>
                            </Button>
                        </StackPane>
                    </VBox>

                    <!-- Rôle avec icônes (Fournisseur / Entrepreneur uniquement) -->
                    <VBox spacing="7">
                        <Label text="Je suis un(e)..."
                               style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #374151;"/>
                        <ChoiceBox fx:id="roleChoice"
                                   style="-fx-pref-width: 999px; -fx-pref-height: 46px;
                                          -fx-background-color: #f9fafb; -fx-background-radius: 12px;
                                          -fx-border-color: #e2e8f0; -fx-border-width: 1.5px;
                                          -fx-border-radius: 12px; -fx-font-size: 13px;
                                          -fx-text-fill: white;"/>
                    </VBox>

                    <!-- Bouton créer -->
                    <Button text="Créer mon compte  →" onAction="#handleRegister"
                            maxWidth="Infinity"
                            style="-fx-pref-height: 50px; -fx-font-size: 14px; -fx-font-weight: bold;
                                   -fx-background-color: #f97316; -fx-text-fill: white;
                                   -fx-background-radius: 12px; -fx-cursor: hand;
                                   -fx-effect: dropshadow(gaussian, rgba(249,115,22,0.5), 16, 0, 0, 6);">
                        <VBox.margin><Insets top="4"/></VBox.margin>
                    </Button>

                    <!-- Lien login -->
                    <HBox alignment="CENTER" spacing="6">
                        <Label text="Déjà un compte ?"
                               style="-fx-text-fill: #6b7280; -fx-font-size: 13px;"/>
                        <Button text="Se connecter →" onAction="#handleGoToLogin"
                                style="-fx-background-color: transparent; -fx-text-fill: #f97316;
                                       -fx-font-weight: bold; -fx-font-size: 13px;
                                       -fx-cursor: hand; -fx-padding: 0; -fx-underline: true;"/>
                    </HBox>

                </VBox>
            </VBox>
        </StackPane>
    </HBox>
</StackPane>
