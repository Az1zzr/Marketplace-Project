<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.web.WebView?>

<VBox spacing="0"
      maxWidth="1.7976931348623157E308"
      maxHeight="1.7976931348623157E308"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="Controller.AjouterLivraisonController">

    <!-- ══ Header ══ -->
    <VBox style="-fx-background-color: white; -fx-background-radius: 16 16 0 0;
                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.07), 8, 0, 0, 2);">
        <Region style="-fx-background-color: #10b981; -fx-pref-height: 4px; -fx-background-radius: 16 16 0 0;"/>
        <HBox alignment="CENTER_LEFT" spacing="16" style="-fx-padding: 18 24 16 24;">
            <Label text="📦" style="-fx-font-size: 24px;"/>
            <VBox spacing="2">
                <Label text="Ajouter une Livraison"
                       style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
                <Label text="Associez une livraison à une commande existante"
                       style="-fx-font-size: 12px; -fx-text-fill: #94a3b8;"/>
            </VBox>
            <Region HBox.hgrow="ALWAYS"/>

            <!-- ✅ AJOUT: Informations de la commande dans le header -->
            <HBox spacing="15" alignment="CENTER_RIGHT">
                <VBox alignment="CENTER_RIGHT" spacing="2">
                    <Label fx:id="idCommandeLabel"
                           style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #10b981;"/>
                    <Label fx:id="commandeInfoLabel"
                           style="-fx-font-size: 11px; -fx-text-fill: #64748b;"/>
                </VBox>
                <Button text="⬅️  Retour" onAction="#retourner"
                        style="-fx-background-color: transparent; -fx-text-fill: #64748b;
                               -fx-font-size: 13px; -fx-border-color: #e2e8f0;
                               -fx-border-width: 1.5px; -fx-border-radius: 10px;
                               -fx-background-radius: 10px; -fx-padding: 8 16; -fx-cursor: hand;"/>
            </HBox>
        </HBox>
    </VBox>

    <!-- ══ Contenu scrollable ══ -->
    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
                style="-fx-background-color: #f8f9fa; -fx-border-color: transparent;">
        <content>
            <AnchorPane style="-fx-background-color: #f8f9fa;">
                <VBox spacing="24" style="-fx-padding: 24 40;"
                      AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0"
                      AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">

                    <!-- ⚠️ BANNIERE D'ERREUR SI PAS DE COMMANDE ⚠️ -->
                    <VBox fx:id="errorBanner" visible="false" managed="false"
                          style="-fx-background-color: #fee2e2; -fx-border-color: #ef4444;
                                 -fx-border-width: 1; -fx-border-radius: 8;
                                 -fx-background-radius: 8; -fx-padding: 12;">
                        <HBox alignment="CENTER_LEFT" spacing="10">
                            <Label text="⚠️" style="-fx-font-size: 16px;"/>
                            <Label text="Aucune commande associée. Retournez à la liste et cliquez sur une commande."
                                   style="-fx-text-fill: #b91c1c; -fx-font-weight: bold;"/>
                        </HBox>
                    </VBox>

                    <!-- Formulaire principal -->
                    <VBox spacing="18"
                          style="-fx-background-color: white; -fx-background-radius: 14;
                                 -fx-border-radius: 14; -fx-border-color: #e0e0e0;
                                 -fx-border-width: 1;
                                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 15, 0, 0, 5);
                                 -fx-padding: 28;">

                        <!-- ✅ AJOUT: Bandeau d'information commande -->
                        <HBox spacing="15" alignment="CENTER_LEFT"
                              style="-fx-background-color: #f0f9ff; -fx-padding: 12;
                                     -fx-background-radius: 8; -fx-border-radius: 8;
                                     -fx-border-color: #bae6fd; -fx-border-width: 1;">
                            <Label text="🛒" style="-fx-font-size: 20px;"/>
                            <VBox spacing="2">
                                <Label text="Commande sélectionnée"
                                       style="-fx-font-size: 11px; -fx-text-fill: #0369a1;"/>
                                <Label fx:id="commandeDetailLabel"
                                       text="Chargement des informations..."
                                       style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #0c4a6e;"/>
                            </VBox>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Label fx:id="commandeStatutLabel"
                                   style="-fx-background-color: #dbeafe; -fx-padding: 4 12;
                                          -fx-background-radius: 20; -fx-text-fill: #1e40af;
                                          -fx-font-size: 11px; -fx-font-weight: bold;"/>
                        </HBox>

                        <Label text="Informations de livraison"
                               style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
                        <Region style="-fx-background-color: #f1f5f9; -fx-pref-height: 1px;"/>

                        <!-- Numéro BL -->
                        <VBox spacing="6">
                            <Label text="Numéro BL (Bon de Livraison)"
                                   style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #374151;"/>
                            <TextField fx:id="numeroBLField" prefHeight="44" promptText="Ex: 001"
                                       style="-fx-font-size: 13px; -fx-padding: 10 14;
                                              -fx-border-color: #FF9800; -fx-border-width: 2;
                                              -fx-border-radius: 8; -fx-background-radius: 8;"/>
                        </VBox>

                        <!-- Date Livraison -->
                        <VBox spacing="6">
                            <Label text="Date de Livraison"
                                   style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #374151;"/>
                            <DatePicker fx:id="dateLivraisonPicker" prefHeight="44"
                                        style="-fx-font-size: 13px;"/>
                        </VBox>

                        <!-- Livreur -->
                        <VBox spacing="6">
                            <Label text="Nom du Livreur"
                                   style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #374151;"/>
                            <TextField fx:id="livreurField" prefHeight="44" promptText="Ex: Tarek Zouari"
                                       style="-fx-font-size: 13px; -fx-padding: 10 14;
                                              -fx-border-color: #FF9800; -fx-border-width: 2;
                                              -fx-border-radius: 8; -fx-background-radius: 8;"/>
                        </VBox>

                        <!-- Statut -->
                        <VBox spacing="6">
                            <Label text="Statut de Livraison"
                                   style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #374151;"/>
                            <ComboBox fx:id="statutLivraisonComboBox" prefHeight="44"
                                      style="-fx-font-size: 13px;"/>
                        </VBox>

                        <!-- Notes -->
                        <VBox spacing="6">
                            <Label text="Notes / Observations"
                                   style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #374151;"/>
                            <TextArea fx:id="noteDeliveryArea" prefHeight="120"
                                      promptText="Entrez vos observations..."
                                      style="-fx-font-size: 13px; -fx-padding: 10 14;
                                             -fx-border-color: #FF9800; -fx-border-width: 2;
                                             -fx-border-radius: 8; -fx-background-radius: 8;"
                                      wrapText="true"/>
                        </VBox>
                    </VBox>

                    <!-- Section Carte -->
                    <VBox spacing="14"
                          style="-fx-background-color: white; -fx-background-radius: 14;
                                 -fx-border-radius: 14; -fx-border-color: #FF9800;
                                 -fx-border-width: 2;
                                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 15, 0, 0, 5);">
                        <HBox alignment="CENTER_LEFT" spacing="12" style="-fx-padding: 18 24 12 24;">
                            <Label text="📍" style="-fx-font-size: 18px;"/>
                            <VBox spacing="2">
                                <Label text="Localisation de la Livraison"
                                       style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
                                <Label text="Facultatif — Cliquez sur la carte pour sélectionner le point de livraison"
                                       style="-fx-font-size: 11px; -fx-text-fill: #94a3b8;"/>
                            </VBox>
                        </HBox>

                        <VBox spacing="10" style="-fx-padding: 0 20 20 20;">
                            <WebView fx:id="mapWebView" prefHeight="360" minHeight="280"
                                     VBox.vgrow="ALWAYS"/>
                            <HBox spacing="16" alignment="CENTER_LEFT">
                                <Label text="Lat :" style="-fx-font-weight: bold; -fx-text-fill: #1f4aa8;"/>
                                <Label fx:id="latLabel" text="—"/>
                                <Label text="Lng :" style="-fx-font-weight: bold; -fx-text-fill: #1f4aa8;"/>
                                <Label fx:id="lngLabel" text="—"/>
                                <Region HBox.hgrow="ALWAYS"/>

                                <!-- ✅ AJOUT: Label d'indication de sélection -->
                                <Label fx:id="mapHintLabel" text="Cliquez sur la carte"
                                       style="-fx-text-fill: #64748b; -fx-font-size: 11px;"/>

                                <Button text="🔄  Réinitialiser" onAction="#handleResetLocation"
                                        style="-fx-background-color: #FF9800; -fx-text-fill: white;
                                               -fx-font-size: 13px; -fx-background-radius: 8px;
                                               -fx-padding: 8 18; -fx-cursor: hand;"/>
                            </HBox>
                        </VBox>
                    </VBox>

                    <!-- Boutons actions -->
                    <HBox alignment="CENTER" spacing="20" style="-fx-padding: 8 0 16 0;">
                        <Button text="✓  AJOUTER" onAction="#ajouterLivraison"
                                prefHeight="50" prefWidth="200"
                                style="-fx-background-color: #10b981; -fx-text-fill: white;
                                       -fx-font-size: 15px; -fx-font-weight: bold;
                                       -fx-background-radius: 10px; -fx-cursor: hand;
                                       -fx-effect: dropshadow(gaussian, rgba(16,185,129,0.4), 8, 0, 0, 3);"/>
                        <Button text="⬅️  RETOUR" onAction="#retourner"
                                prefHeight="50" prefWidth="200"
                                style="-fx-background-color: #1F4AA8; -fx-text-fill: white;
                                       -fx-font-size: 15px; -fx-font-weight: bold;
                                       -fx-background-radius: 10px; -fx-cursor: hand;"/>
                        <Button text="🗑️  EFFACER" onAction="#effacer"
                                prefHeight="50" prefWidth="200"
                                style="-fx-background-color: #fef2f2; -fx-text-fill: #ef4444;
                                       -fx-font-size: 15px; -fx-font-weight: bold;
                                       -fx-background-radius: 10px; -fx-cursor: hand;
                                       -fx-border-color: #fecaca; -fx-border-width: 1.5px; -fx-border-radius: 10px;"/>
                    </HBox>

                </VBox>
            </AnchorPane>
        </content>
    </ScrollPane>
</VBox>