<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<!--
    AjouterCommandeView.fxml — Version Dashboard
    Navbar retirée, style adapté au thème dashboard.
-->
<VBox spacing="0"
      maxWidth="1.7976931348623157E308"
      maxHeight="1.7976931348623157E308"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="Controller.AjouterCommandeController">

    <!-- ══ Header ══ -->
    <VBox style="-fx-background-color: white; -fx-background-radius: 16 16 0 0;
                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.07), 8, 0, 0, 2);">
        <Region style="-fx-background-color: #f97316; -fx-pref-height: 4px; -fx-background-radius: 16 16 0 0;"/>
        <HBox alignment="CENTER_LEFT" spacing="16" style="-fx-padding: 18 24 16 24;">
            <Label text="➕" style="-fx-font-size: 24px;"/>
            <VBox spacing="2">
                <Label text="Ajouter une Commande"
                       style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
                <Label text="Remplissez le formulaire ci-dessous"
                       style="-fx-font-size: 12px; -fx-text-fill: #94a3b8;"/>
            </VBox>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="📋  Mes Commandes" onAction="#afficherCommandes"
                    style="-fx-background-color: transparent; -fx-text-fill: #f97316;
                           -fx-font-size: 13px; -fx-font-weight: bold;
                           -fx-border-color: #f97316; -fx-border-width: 1.5px;
                           -fx-border-radius: 10px; -fx-background-radius: 10px;
                           -fx-padding: 8 16; -fx-cursor: hand;"/>
        </HBox>
    </VBox>

    <!-- ══ Contenu scrollable ══ -->
    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                style="-fx-background-color: #f5f5f5; -fx-border-color: transparent;">
        <content>
            <VBox spacing="20" style="-fx-padding: 24 32; -fx-background-color: #f5f5f5;">

                <!-- Carte formulaire -->
                <VBox spacing="16"
                      style="-fx-background-color: white; -fx-padding: 28;
                             -fx-background-radius: 14px;
                             -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.07), 10, 0, 0, 3);
                             -fx-border-color: #f1f5f9; -fx-border-width: 1.5px; -fx-border-radius: 14px;">

                    <Label text="Informations de la commande"
                           style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
                    <Region style="-fx-background-color: #f1f5f9; -fx-pref-height: 1px;"/>

                    <!-- Numéro de Commande -->
                    <VBox spacing="6">
                        <Label text="Numéro de Commande"
                               style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #374151;"/>
                        <TextField fx:id="numeroCommandeField" promptText="Ex: CMD001"
                                   style="-fx-pref-height: 42px; -fx-font-size: 13px;
                                          -fx-background-color: white; -fx-border-color: #FF9800;
                                          -fx-border-width: 2; -fx-border-radius: 8px;
                                          -fx-background-radius: 8px; -fx-padding: 8 14;"/>
                    </VBox>

                    <!-- Nom du Client -->
                    <VBox spacing="6">
                        <Label text="Nom du Client"
                               style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #374151;"/>
                        <TextField fx:id="nomClientField" promptText="Ex: Mohamed Ali"
                                   style="-fx-pref-height: 42px; -fx-font-size: 13px;
                                          -fx-background-color: white; -fx-border-color: #FF9800;
                                          -fx-border-width: 2; -fx-border-radius: 8px;
                                          -fx-background-radius: 8px; -fx-padding: 8 14;"/>
                    </VBox>

                    <!-- Date de la Commande -->
                    <VBox spacing="6">
                        <Label text="Date de la Commande"
                               style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #374151;"/>
                        <DatePicker fx:id="dateCommandePicker"
                                    style="-fx-pref-height: 42px; -fx-font-size: 13px;"/>
                    </VBox>

                    <!-- Montant Total -->
                    <VBox spacing="6">
                        <Label text="Montant Total (TND)"
                               style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #374151;"/>
                        <TextField fx:id="montantField" promptText="Ex: 450.00"
                                   style="-fx-pref-height: 42px; -fx-font-size: 13px;
                                          -fx-background-color: white; -fx-border-color: #FF9800;
                                          -fx-border-width: 2; -fx-border-radius: 8px;
                                          -fx-background-radius: 8px; -fx-padding: 8 14;"/>
                    </VBox>

                    <!-- Adresse de Livraison -->
                    <VBox spacing="6">
                        <Label text="Adresse de Livraison"
                               style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #374151;"/>
                        <TextField fx:id="adresseLivraisonField" promptText="Ex: 123 Rue de la Paix, Tunis"
                                   style="-fx-pref-height: 42px; -fx-font-size: 13px;
                                          -fx-background-color: white; -fx-border-color: #FF9800;
                                          -fx-border-width: 2; -fx-border-radius: 8px;
                                          -fx-background-radius: 8px; -fx-padding: 8 14;"/>
                    </VBox>

                    <!-- Statut -->
                    <VBox spacing="6">
                        <Label text="Statut"
                               style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #374151;"/>
                        <ComboBox fx:id="statutComboBox" prefWidth="280"
                                  style="-fx-pref-height: 42px; -fx-font-size: 13px;"/>
                    </VBox>
                </VBox>

                <!-- Boutons actions -->
                <HBox alignment="CENTER_LEFT" spacing="14" style="-fx-padding: 0 0 8 0;">
                    <Button fx:id="ajouterButton" text="✓  AJOUTER" onAction="#ajouterCommande"
                            prefHeight="48"
                            style="-fx-background-color: #10b981; -fx-text-fill: white;
                                   -fx-font-size: 14px; -fx-font-weight: bold;
                                   -fx-background-radius: 10px; -fx-padding: 0 28; -fx-cursor: hand;
                                   -fx-effect: dropshadow(gaussian, rgba(16,185,129,0.4), 8, 0, 0, 3);"/>
                    <Button fx:id="payerButton" text="💳  PAYER" onAction="#ouvrirPaiement"
                            prefHeight="48"
                            style="-fx-background-color: #1F4AA8; -fx-text-fill: white;
                                   -fx-font-size: 14px; -fx-font-weight: bold;
                                   -fx-background-radius: 10px; -fx-padding: 0 28; -fx-cursor: hand;"/>
                    <Button fx:id="afficherButton" text="📋  MES COMMANDES" onAction="#afficherCommandes"
                            prefHeight="48"
                            style="-fx-background-color: #FF9800; -fx-text-fill: white;
                                   -fx-font-size: 14px; -fx-font-weight: bold;
                                   -fx-background-radius: 10px; -fx-padding: 0 28; -fx-cursor: hand;"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button fx:id="effacerButton" text="🗑️  EFFACER" onAction="#effacerFormulaire"
                            prefHeight="48"
                            style="-fx-background-color: #fef2f2; -fx-text-fill: #ef4444;
                                   -fx-font-size: 13px; -fx-font-weight: bold;
                                   -fx-background-radius: 10px; -fx-padding: 0 20; -fx-cursor: hand;
                                   -fx-border-color: #fecaca; -fx-border-width: 1.5px; -fx-border-radius: 10px;"/>
                </HBox>
            </VBox>
        </content>
    </ScrollPane>
</VBox>
