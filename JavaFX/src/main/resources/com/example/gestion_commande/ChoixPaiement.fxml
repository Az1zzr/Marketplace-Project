<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.*?>

<!--
    ChoixPaiement.fxml — Version Dashboard
    Header adapté au thème dashboard.
    Intégré dans le contentArea du UserDashboard.
-->
<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="Controller.ChoixPaiementController"
      spacing="0"
      maxWidth="1.7976931348623157E308"
      maxHeight="1.7976931348623157E308"
      style="-fx-background-color: #F5F5F5;">

    <!-- ══ Header adapté dashboard ══ -->
    <VBox style="-fx-background-color: white; -fx-background-radius: 16 16 0 0;
                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.07), 8, 0, 0, 2);">
        <Region style="-fx-background-color: #4F46E5; -fx-pref-height: 4px; -fx-background-radius: 16 16 0 0;"/>
        <HBox alignment="CENTER_LEFT" spacing="16" style="-fx-padding: 16 24;">
            <Label text="💳" style="-fx-font-size: 24px;"/>
            <VBox spacing="2">
                <Label fx:id="titleLabel" text="Choisir la méthode de paiement"
                       style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
                <Label fx:id="montantLabel" text="Montant : --"
                       style="-fx-font-size: 13px; -fx-text-fill: #f97316; -fx-font-weight: bold;"/>
            </VBox>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="⬅️  Retour" onAction="#annuler"
                    style="-fx-background-color: transparent; -fx-text-fill: #64748b;
                           -fx-font-size: 13px; -fx-border-color: #e2e8f0;
                           -fx-border-width: 1.5px; -fx-border-radius: 10px;
                           -fx-background-radius: 10px; -fx-padding: 8 16; -fx-cursor: hand;"/>
        </HBox>
    </VBox>

    <!-- ══ Contenu principal ══ -->
    <HBox spacing="20" VBox.vgrow="ALWAYS" style="-fx-padding: 24;">

        <!-- Colonne gauche : modes de paiement + code promo -->
        <VBox spacing="14" prefWidth="380">

            <Label text="💳 Mode de paiement"
                   style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>

            <Button fx:id="btnOnline" text="💳  Paiement en Ligne" maxWidth="Infinity"
                    style="-fx-background-color: #4F46E5; -fx-text-fill: white; -fx-font-size: 14px;
                           -fx-padding: 16; -fx-cursor: hand; -fx-background-radius: 10px;
                           -fx-effect: dropshadow(gaussian, rgba(79,70,229,0.4), 8, 0, 0, 3);"/>
            <Button fx:id="btnTPE" text="🏪  Paiement TPE" maxWidth="Infinity"
                    style="-fx-background-color: #F59E0B; -fx-text-fill: white; -fx-font-size: 14px;
                           -fx-padding: 16; -fx-cursor: hand; -fx-background-radius: 10px;"/>
            <Button fx:id="btnEspece" text="💵  Paiement Espèces" maxWidth="Infinity"
                    style="-fx-background-color: #10B981; -fx-text-fill: white; -fx-font-size: 14px;
                           -fx-padding: 16; -fx-cursor: hand; -fx-background-radius: 10px;"/>

            <Separator/>

            <!-- Section Code Promo -->
            <VBox spacing="10"
                  style="-fx-background-color: #FFF8E1; -fx-border-color: #FFB300;
                         -fx-border-radius: 10; -fx-background-radius: 10; -fx-padding: 16;">
                <Label text="🎟️  Code Promo"
                       style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #E65100;"/>
                <HBox spacing="8">
                    <TextField fx:id="promoCodeField"
                               promptText="Ex: WELCOME10, VIP, PROMO20..."
                               HBox.hgrow="ALWAYS"
                               style="-fx-font-size: 13px; -fx-background-radius: 8px;
                                      -fx-border-color: #FFB300; -fx-border-radius: 8px;
                                      -fx-padding: 10; -fx-pref-height: 40px;"/>
                    <Button fx:id="btnAppliquerPromo" text="Appliquer" onAction="#appliquerCodePromo"
                            style="-fx-background-color: #FF9800; -fx-text-fill: white;
                                   -fx-font-size: 13px; -fx-font-weight: bold; -fx-cursor: hand;
                                   -fx-background-radius: 8px; -fx-padding: 0 16; -fx-pref-height: 40px;"/>
                </HBox>
                <Label fx:id="promoResultLabel" text=""
                       style="-fx-font-size: 12px;" wrapText="true"/>
                <Label fx:id="montantFinalLabel" text=""
                       style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #1F4AA8;"
                       wrapText="true"/>
                <Label text="Codes dispo : WELCOME10 · PROMO20 · VIP · SOLDES50 · REDUC5EUR · REDUC10EUR"
                       style="-fx-font-size: 10px; -fx-text-fill: #888;" wrapText="true"/>
            </VBox>

            <Region VBox.vgrow="ALWAYS"/>

            <Button fx:id="btnAnnuler" text="❌  Annuler" maxWidth="Infinity" onAction="#annuler"
                    style="-fx-background-color: #fef2f2; -fx-text-fill: #ef4444;
                           -fx-font-size: 14px; -fx-font-weight: bold; -fx-padding: 14;
                           -fx-cursor: hand; -fx-background-radius: 10px;
                           -fx-border-color: #fecaca; -fx-border-width: 1.5px; -fx-border-radius: 10px;"/>
        </VBox>

        <!-- Colonne droite : récapitulatif commande -->
        <VBox spacing="12" HBox.hgrow="ALWAYS">
            <Label text="📋  Récapitulatif de la commande"
                   style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
            <TextArea fx:id="detailsCommande"
                      editable="false" wrapText="true"
                      VBox.vgrow="ALWAYS"
                      style="-fx-font-size: 13px; -fx-background-color: white;
                             -fx-border-color: #e2e8f0; -fx-border-radius: 12px;
                             -fx-background-radius: 12px; -fx-padding: 16;
                             -fx-font-family: 'Courier New';
                             -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 8, 0, 0, 2);"/>
        </VBox>
    </HBox>
</VBox>
