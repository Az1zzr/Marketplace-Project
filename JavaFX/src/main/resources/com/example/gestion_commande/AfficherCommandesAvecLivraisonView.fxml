<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<!--
    AfficherCommandesAvecLivraisonView.fxml — Version Dashboard
    Navbar retirée, intégrée dans le contentArea du UserDashboard.
-->
<VBox spacing="0"
      maxWidth="1.7976931348623157E308"
      maxHeight="1.7976931348623157E308"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="Controller.AfficherCommandesAvecLivraisonController">

    <!-- ══ Header ══ -->
    <VBox style="-fx-background-color: white; -fx-background-radius: 16 16 0 0;
                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.07), 8, 0, 0, 2);">
        <Region style="-fx-background-color: #FF9800; -fx-pref-height: 4px; -fx-background-radius: 16 16 0 0;"/>
        <HBox alignment="CENTER_LEFT" spacing="16" style="-fx-padding: 18 24 16 24;">
            <Label text="🚚" style="-fx-font-size: 24px;"/>
            <VBox spacing="2">
                <Label text="Commandes avec Livraison"
                       style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
                <Label text="Suivez le statut de vos livraisons en temps réel"
                       style="-fx-font-size: 12px; -fx-text-fill: #94a3b8;"/>
            </VBox>
            <Region HBox.hgrow="ALWAYS"/>
            <!-- Boutons actions rapides -->
            <Button text="📅  Calendrier" onAction="#ouvrirCalendrier"
                    style="-fx-background-color: #1F4AA8; -fx-text-fill: white;
                           -fx-font-size: 13px; -fx-font-weight: bold;
                           -fx-background-radius: 10px; -fx-padding: 10 16; -fx-cursor: hand;"/>
            <Button text="🗓  Google Calendar" onAction="#exporterVersGoogleCalendar"
                    style="-fx-background-color: #EA4335; -fx-text-fill: white;
                           -fx-font-size: 13px; -fx-font-weight: bold;
                           -fx-background-radius: 10px; -fx-padding: 10 16; -fx-cursor: hand;"/>
        </HBox>
    </VBox>

    <!-- ══ Zone principale + Chatbot sidebar ══ -->
    <HBox VBox.vgrow="ALWAYS" style="-fx-background-color: #f5f1ee;">

        <!-- ══ Liste commandes ══ -->
        <VBox HBox.hgrow="ALWAYS" spacing="0">
            <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                        style="-fx-background-color: #f5f1ee;
                               -fx-border-color: #FF9800; -fx-border-width: 2;">
                <content>
                    <VBox fx:id="commandesVBox" spacing="10.0"
                          style="-fx-background-color: #f5f1ee;">
                        <padding>
                            <Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/>
                        </padding>
                    </VBox>
                </content>
            </ScrollPane>

            <!-- Barre bas -->
            <HBox alignment="CENTER" spacing="16"
                  style="-fx-padding: 14 20; -fx-background-color: white;
                         -fx-border-color: #e5e9f0; -fx-border-width: 1 0 0 0;">
                <Button text="⬅️  Mes Commandes" onAction="#retourner"
                        prefHeight="44"
                        style="-fx-background-color: #1F4AA8; -fx-text-fill: white;
                               -fx-font-size: 13px; -fx-font-weight: bold;
                               -fx-background-radius: 10px; -fx-padding: 0 22; -fx-cursor: hand;"/>
                <Button text="🔄  Actualiser" onAction="#actualiser"
                        prefHeight="44"
                        style="-fx-background-color: #10b981; -fx-text-fill: white;
                               -fx-font-size: 13px; -fx-font-weight: bold;
                               -fx-background-radius: 10px; -fx-padding: 0 22; -fx-cursor: hand;"/>
            </HBox>
        </VBox>

        <!-- ══ Sidebar Chatbot ══ (conservé tel quel du projet original) -->
        <VBox fx:id="chatbotSidebar" prefWidth="320" spacing="0"
              style="-fx-background-color: white;
                     -fx-border-color: #e0e0e0; -fx-border-width: 0 0 0 1;">
            <!-- Header chatbot -->
            <HBox alignment="CENTER_LEFT" spacing="10"
                  style="-fx-background-color: #1F4AA8; -fx-padding: 14 16;">
                <Label text="🤖" style="-fx-font-size: 20px;"/>
                <VBox spacing="2">
                    <Label text="Assistant IA"
                           style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                    <Label text="Posez vos questions sur vos commandes"
                           style="-fx-font-size: 10px; -fx-text-fill: rgba(255,255,255,0.7);"/>
                </VBox>
            </HBox>
            <!-- Zone messages -->
            <ScrollPane fx:id="chatScrollPane" fitToWidth="true" VBox.vgrow="ALWAYS"
                        style="-fx-background-color: #f8f9fa; -fx-border-color: transparent;">
                <content>
                    <VBox fx:id="chatMessagesBox" spacing="10"
                          style="-fx-padding: 16; -fx-background-color: #f8f9fa;"/>
                </content>
            </ScrollPane>
            <!-- Zone saisie -->
            <HBox spacing="10" style="-fx-padding: 12; -fx-background-color: white;
                                      -fx-border-color: #e0e0e0; -fx-border-width: 1 0 0 0;">
                <TextField fx:id="chatInput" HBox.hgrow="ALWAYS"
                           promptText="Posez votre question..."
                           style="-fx-pref-height: 38px; -fx-font-size: 13px;
                                  -fx-background-radius: 8px; -fx-border-color: #e0e0e0;
                                  -fx-border-radius: 8px; -fx-padding: 0 12;"
                           onAction="#onSendMessage"/>
                <Button text="➤" onAction="#onSendMessage"
                        style="-fx-background-color: #1F4AA8; -fx-text-fill: white;
                               -fx-font-size: 16px; -fx-background-radius: 8px;
                               -fx-pref-width: 40px; -fx-pref-height: 38px; -fx-cursor: hand;"/>
            </HBox>
        </VBox>
    </HBox>
</VBox>
