<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<!--
    CalendrierLivraisons.fxml — Version Dashboard
    Header adapté au thème dashboard (orange + blanc).
    Intégré dans le contentArea du UserDashboard.
-->
<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="Controller.CalendrierLivraisonsController"
            maxWidth="1.7976931348623157E308"
            maxHeight="1.7976931348623157E308"
            style="-fx-background-color: #f1f4f9;">

    <!-- ══ Header adapté dashboard ══ -->
    <top>
        <VBox style="-fx-background-color: white;
                     -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.07), 8, 0, 0, 2);">
            <Region style="-fx-background-color: #1F4AA8; -fx-pref-height: 4px;"/>
            <HBox alignment="CENTER_LEFT" spacing="16" style="-fx-padding: 16 24;">
                <Label text="📅" style="-fx-font-size: 24px;"/>
                <VBox spacing="2">
                    <Label text="Calendrier des Livraisons"
                           style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
                    <Label fx:id="lblSousTitre" text="Vue mensuelle des commandes et livraisons"
                           style="-fx-font-size: 11px; -fx-text-fill: #94a3b8;"/>
                </VBox>
                <Region HBox.hgrow="ALWAYS"/>
                <Button onAction="#exporterTousVersGoogle" text="🗓  Sync Google Calendar"
                        style="-fx-background-color: #EA4335; -fx-text-fill: white;
                               -fx-font-size: 13px; -fx-font-weight: bold; -fx-cursor: hand;
                               -fx-background-radius: 8; -fx-padding: 10 18;"/>
                <Button onAction="#actualiser" text="⟳  Actualiser"
                        style="-fx-background-color: #f1f4f9; -fx-text-fill: #374151;
                               -fx-font-size: 13px; -fx-font-weight: bold; -fx-cursor: hand;
                               -fx-background-radius: 8; -fx-padding: 10 16;
                               -fx-border-color: #e2e8f0; -fx-border-width: 1.5px; -fx-border-radius: 8;"/>
                <Button onAction="#retourner" text="⬅️  Retour"
                        style="-fx-background-color: transparent; -fx-text-fill: #64748b;
                               -fx-font-size: 13px; -fx-cursor: hand;
                               -fx-background-radius: 8; -fx-padding: 10 16;
                               -fx-border-color: #e2e8f0; -fx-border-width: 1.5px; -fx-border-radius: 8;"/>
            </HBox>
        </VBox>
    </top>

    <!-- ══ Center — calendrier ══ -->
    <center>
        <VBox spacing="0" style="-fx-padding: 20 24;">

            <!-- Navigation mois + légende -->
            <HBox alignment="CENTER_LEFT" spacing="16" style="-fx-padding: 0 0 16 0;">
                <Button onAction="#moisPrecedent" text="◀"
                        style="-fx-background-color: #1F4AA8; -fx-text-fill: white;
                               -fx-font-size: 16px; -fx-font-weight: bold;
                               -fx-cursor: hand; -fx-background-radius: 8; -fx-padding: 8 14;"/>
                <Label fx:id="lblMoisAnnee" text="Janvier 2025"
                       style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #1e293b;
                              -fx-min-width: 220; -fx-alignment: CENTER;"/>
                <Button onAction="#moisSuivant" text="▶"
                        style="-fx-background-color: #1F4AA8; -fx-text-fill: white;
                               -fx-font-size: 16px; -fx-font-weight: bold;
                               -fx-cursor: hand; -fx-background-radius: 8; -fx-padding: 8 14;"/>
                <Button onAction="#allerAujourdhui" text="Aujourd'hui"
                        style="-fx-background-color: #FF9800; -fx-text-fill: white;
                               -fx-font-size: 13px; -fx-font-weight: bold;
                               -fx-cursor: hand; -fx-background-radius: 8; -fx-padding: 8 16;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <!-- Légende -->
                <HBox alignment="CENTER_LEFT" spacing="16">
                    <HBox alignment="CENTER_LEFT" spacing="6">
                        <Region style="-fx-background-color: #4CAF50; -fx-background-radius: 50%;
                                       -fx-min-width: 14; -fx-min-height: 14;"/>
                        <Label text="Livré" style="-fx-font-size: 12px; -fx-text-fill: #555;"/>
                    </HBox>
                    <HBox alignment="CENTER_LEFT" spacing="6">
                        <Region style="-fx-background-color: #FF9800; -fx-background-radius: 50%;
                                       -fx-min-width: 14; -fx-min-height: 14;"/>
                        <Label text="En cours" style="-fx-font-size: 12px; -fx-text-fill: #555;"/>
                    </HBox>
                    <HBox alignment="CENTER_LEFT" spacing="6">
                        <Region style="-fx-background-color: #d9534f; -fx-background-radius: 50%;
                                       -fx-min-width: 14; -fx-min-height: 14;"/>
                        <Label text="En attente" style="-fx-font-size: 12px; -fx-text-fill: #555;"/>
                    </HBox>
                    <HBox alignment="CENTER_LEFT" spacing="6">
                        <Region style="-fx-background-color: #1F4AA8; -fx-background-radius: 50%;
                                       -fx-min-width: 14; -fx-min-height: 14;"/>
                        <Label text="Payée" style="-fx-font-size: 12px; -fx-text-fill: #555;"/>
                    </HBox>
                </HBox>
            </HBox>

            <!-- Grille calendrier -->
            <VBox spacing="0"
                  style="-fx-background-color: white; -fx-background-radius: 16px;
                         -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.08),12,0,0,3);">
                <!-- En-têtes jours -->
                <GridPane style="-fx-background-color: #1F4AA8; -fx-background-radius: 16 16 0 0;">
                    <columnConstraints>
                        <ColumnConstraints percentWidth="14.285" hgrow="ALWAYS"/>
                        <ColumnConstraints percentWidth="14.285" hgrow="ALWAYS"/>
                        <ColumnConstraints percentWidth="14.285" hgrow="ALWAYS"/>
                        <ColumnConstraints percentWidth="14.285" hgrow="ALWAYS"/>
                        <ColumnConstraints percentWidth="14.285" hgrow="ALWAYS"/>
                        <ColumnConstraints percentWidth="14.285" hgrow="ALWAYS"/>
                        <ColumnConstraints percentWidth="14.285" hgrow="ALWAYS"/>
                    </columnConstraints>
                    <Label text="Lundi" alignment="CENTER" maxWidth="Infinity" GridPane.columnIndex="0"
                           style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 13px; -fx-padding: 12 0;"/>
                    <Label text="Mardi" alignment="CENTER" maxWidth="Infinity" GridPane.columnIndex="1"
                           style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 13px; -fx-padding: 12 0;"/>
                    <Label text="Mercredi" alignment="CENTER" maxWidth="Infinity" GridPane.columnIndex="2"
                           style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 13px; -fx-padding: 12 0;"/>
                    <Label text="Jeudi" alignment="CENTER" maxWidth="Infinity" GridPane.columnIndex="3"
                           style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 13px; -fx-padding: 12 0;"/>
                    <Label text="Vendredi" alignment="CENTER" maxWidth="Infinity" GridPane.columnIndex="4"
                           style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 13px; -fx-padding: 12 0;"/>
                    <Label text="Samedi" alignment="CENTER" maxWidth="Infinity" GridPane.columnIndex="5"
                           style="-fx-text-fill: rgba(255,255,255,0.7); -fx-font-size: 13px; -fx-padding: 12 0;"/>
                    <Label text="Dimanche" alignment="CENTER" maxWidth="Infinity" GridPane.columnIndex="6"
                           style="-fx-text-fill: rgba(255,100,100,0.9); -fx-font-size: 13px; -fx-padding: 12 0;"/>
                </GridPane>

                <!-- Grille des jours (remplie dynamiquement) -->
                <GridPane fx:id="grilleCalendrier" VBox.vgrow="ALWAYS"
                          style="-fx-background-color: white; -fx-background-radius: 0 0 16 16;">
                    <columnConstraints>
                        <ColumnConstraints percentWidth="14.285" hgrow="ALWAYS"/>
                        <ColumnConstraints percentWidth="14.285" hgrow="ALWAYS"/>
                        <ColumnConstraints percentWidth="14.285" hgrow="ALWAYS"/>
                        <ColumnConstraints percentWidth="14.285" hgrow="ALWAYS"/>
                        <ColumnConstraints percentWidth="14.285" hgrow="ALWAYS"/>
                        <ColumnConstraints percentWidth="14.285" hgrow="ALWAYS"/>
                        <ColumnConstraints percentWidth="14.285" hgrow="ALWAYS"/>
                    </columnConstraints>
                    <rowConstraints>
                        <RowConstraints minHeight="90" vgrow="ALWAYS"/>
                        <RowConstraints minHeight="90" vgrow="ALWAYS"/>
                        <RowConstraints minHeight="90" vgrow="ALWAYS"/>
                        <RowConstraints minHeight="90" vgrow="ALWAYS"/>
                        <RowConstraints minHeight="90" vgrow="ALWAYS"/>
                        <RowConstraints minHeight="90" vgrow="ALWAYS"/>
                    </rowConstraints>
                </GridPane>
            </VBox>

            <!-- Panel détail sélection -->
            <ScrollPane fx:id="detailScrollPane"
                        fitToWidth="true" hbarPolicy="NEVER"
                        maxHeight="180"
                        style="-fx-background-color: transparent; -fx-border-color: transparent;">
                <content>
                    <VBox fx:id="detailPanel" spacing="0" style="-fx-padding: 12 0 0 0;"/>
                </content>
            </ScrollPane>
        </VBox>
    </center>

    <!-- ══ Bottom — Stats ══ -->
    <bottom>
        <HBox spacing="12" alignment="CENTER"
              style="-fx-padding: 10 24 14 24; -fx-background-color: #f1f4f9;">
            <VBox spacing="0" HBox.hgrow="ALWAYS"
                  style="-fx-background-color: white; -fx-background-radius: 12;
                         -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.06),8,0,0,2);">
                <Region style="-fx-background-color: #1F4AA8; -fx-background-radius: 12 12 0 0; -fx-pref-height: 3px;"/>
                <VBox style="-fx-padding: 10 16;">
                    <Label fx:id="lblTotalCommandes" text="—"
                           style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #1F4AA8;"/>
                    <Label text="Total commandes" style="-fx-font-size: 11px; -fx-text-fill: #94a3b8;"/>
                </VBox>
            </VBox>
            <VBox spacing="0" HBox.hgrow="ALWAYS"
                  style="-fx-background-color: white; -fx-background-radius: 12;
                         -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.06),8,0,0,2);">
                <Region style="-fx-background-color: #4CAF50; -fx-background-radius: 12 12 0 0; -fx-pref-height: 3px;"/>
                <VBox style="-fx-padding: 10 16;">
                    <Label fx:id="lblTotalLivrees" text="—"
                           style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #4CAF50;"/>
                    <Label text="Livrées ce mois" style="-fx-font-size: 11px; -fx-text-fill: #94a3b8;"/>
                </VBox>
            </VBox>
            <VBox spacing="0" HBox.hgrow="ALWAYS"
                  style="-fx-background-color: white; -fx-background-radius: 12;
                         -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.06),8,0,0,2);">
                <Region style="-fx-background-color: #FF9800; -fx-background-radius: 12 12 0 0; -fx-pref-height: 3px;"/>
                <VBox style="-fx-padding: 10 16;">
                    <Label fx:id="lblTotalEnCours" text="—"
                           style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #FF9800;"/>
                    <Label text="En cours" style="-fx-font-size: 11px; -fx-text-fill: #94a3b8;"/>
                </VBox>
            </VBox>
            <VBox spacing="0" HBox.hgrow="ALWAYS"
                  style="-fx-background-color: white; -fx-background-radius: 12;
                         -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.06),8,0,0,2);">
                <Region style="-fx-background-color: #d9534f; -fx-background-radius: 12 12 0 0; -fx-pref-height: 3px;"/>
                <VBox style="-fx-padding: 10 16;">
                    <Label fx:id="lblSansLivraison" text="—"
                           style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #d9534f;"/>
                    <Label text="Sans livraison" style="-fx-font-size: 11px; -fx-text-fill: #94a3b8;"/>
                </VBox>
            </VBox>
        </HBox>
    </bottom>
</BorderPane>
