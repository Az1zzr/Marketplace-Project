<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="Controller.MessagingController"
      spacing="16"
      style="-fx-background-color: transparent;">

    <HBox alignment="CENTER_LEFT" spacing="12">
        <VBox spacing="2">
            <Label text="Messages"
                   style="-fx-font-size:22px;-fx-font-weight:bold;-fx-text-fill:#1e293b;"/>
            <Label text="Conversations privées entre clients et fournisseurs"
                   style="-fx-font-size:12px;-fx-text-fill:#94a3b8;"/>
        </VBox>
        <Region HBox.hgrow="ALWAYS"/>
        <ComboBox fx:id="supplierCombo" promptText="Choisir un fournisseur" prefWidth="240"
                  style="-fx-background-color:white;-fx-border-color:#e5e9f0;-fx-border-radius:10;-fx-background-radius:10;"/>
        <Button fx:id="startConversationButton" text="Nouvelle conversation" onAction="#startConversation"
                style="-fx-background-color:#f97316;-fx-text-fill:white;-fx-font-weight:bold;-fx-background-radius:10;-fx-padding:10 16;"/>
        <Button fx:id="refreshButton" text="Actualiser" onAction="#refresh"
                style="-fx-background-color:white;-fx-text-fill:#1e293b;-fx-font-weight:bold;-fx-background-radius:10;-fx-padding:10 16;-fx-border-color:#e5e9f0;-fx-border-radius:10;"/>
    </HBox>

    <HBox spacing="16" VBox.vgrow="ALWAYS">
        <VBox prefWidth="310" spacing="10"
              style="-fx-background-color:white;-fx-background-radius:16;-fx-padding:14;-fx-effect:dropshadow(gaussian,rgba(0,0,0,0.07),10,0,0,3);">
            <Label text="Conversations" style="-fx-font-size:15px;-fx-font-weight:bold;-fx-text-fill:#1e293b;"/>
            <ListView fx:id="conversationList" VBox.vgrow="ALWAYS"
                      style="-fx-background-color:transparent;-fx-border-color:#f1f4f9;-fx-border-radius:10;"/>
        </VBox>

        <VBox spacing="12" HBox.hgrow="ALWAYS"
              style="-fx-background-color:white;-fx-background-radius:16;-fx-padding:16;-fx-effect:dropshadow(gaussian,rgba(0,0,0,0.07),10,0,0,3);">
            <VBox spacing="2">
                <Label fx:id="conversationTitle" text="Messages"
                       style="-fx-font-size:18px;-fx-font-weight:bold;-fx-text-fill:#1e293b;"/>
                <Label fx:id="helperLabel" text="Sélectionnez une conversation."
                       style="-fx-font-size:12px;-fx-text-fill:#94a3b8;"/>
            </VBox>

            <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                        style="-fx-background-color:#f8fafc;-fx-background:#f8fafc;-fx-border-color:#e5e9f0;-fx-border-radius:12;">
                <VBox fx:id="messagesBox" spacing="10" style="-fx-padding:14;"/>
            </ScrollPane>

            <HBox spacing="10" alignment="CENTER_LEFT">
                <TextArea fx:id="messageField" promptText="Écrire un message..." prefRowCount="2" HBox.hgrow="ALWAYS"
                          style="-fx-background-color:#f8fafc;-fx-border-color:#e5e9f0;-fx-border-radius:10;-fx-background-radius:10;"/>
                <Button fx:id="sendButton" text="Envoyer" onAction="#sendMessage"
                        style="-fx-background-color:#f97316;-fx-text-fill:white;-fx-font-weight:bold;-fx-background-radius:10;-fx-padding:14 22;"/>
            </HBox>
        </VBox>
    </HBox>
</VBox>
