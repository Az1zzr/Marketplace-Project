<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.shape.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="Controller.UserDashboardController"
            prefWidth="1280" prefHeight="780"
            style="-fx-background-color: #0d1b2e;">
    <left>
        <VBox prefWidth="252" spacing="0"
              style="-fx-background-color: #0d1b2e; -fx-border-color: #1a2d47; -fx-border-width: 0 1 0 0;">

            <!-- Logo -->
            <HBox alignment="CENTER" style="-fx-padding: 18 16 12 16; -fx-background-color: #091422;">
                <ImageView fitWidth="160" fitHeight="80" preserveRatio="true" smooth="true">
                    <image><Image url="@/images/logo_localtrade.png"/></image>
                </ImageView>
            </HBox>

            <!-- Badge rôle dynamique -->
            <HBox alignment="CENTER" style="-fx-padding: 6 0 10 0; -fx-background-color: #091422;">
                <Label fx:id="lblRoleBadge" text="UTILISATEUR"
                       style="-fx-font-size: 10px; -fx-font-weight: bold; -fx-text-fill: #f97316;
                              -fx-background-color: rgba(249,115,22,0.1);
                              -fx-background-radius: 20px; -fx-padding: 4 14;"/>
            </HBox>

            <Region style="-fx-background-color: #f97316; -fx-pref-height: 2px;"/>
            <Region style="-fx-background-color: #1a2d47; -fx-pref-height: 1px;"/>

            <!-- Menu -->
            <ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="NEVER"
                        style="-fx-background: transparent; -fx-background-color: transparent; -fx-border-color: transparent;"
                        VBox.vgrow="ALWAYS">
                <VBox spacing="3" style="-fx-padding: 14 10 10 10;">

                    <!-- ══ MON COMPTE ══ -->
                    <Label text="MON COMPTE"
                           style="-fx-font-size: 9px; -fx-font-weight: bold; -fx-text-fill: #3a5070; -fx-padding: 4 8 4 8;"/>
                    <Button fx:id="btnAccueil" text="👤   Mon Compte" maxWidth="Infinity" onAction="#showAccueil"
                            style="-fx-background-color: #f97316; -fx-text-fill: white; -fx-font-size: 13px;
                                   -fx-font-weight: bold; -fx-alignment: CENTER_LEFT; -fx-padding: 12 16;
                                   -fx-background-radius: 10px; -fx-cursor: hand;"/>

                    <!-- ══ MES ACTIVITÉS ══ -->
                    <Label text="MES ACTIVITÉS"
                           style="-fx-font-size: 9px; -fx-font-weight: bold; -fx-text-fill: #3a5070; -fx-padding: 10 8 4 8;"/>
                    <Button fx:id="btnProduits" text="📦   Mes Produits" maxWidth="Infinity" onAction="#showProduits"
                            style="-fx-background-color: transparent; -fx-text-fill: #7a9ab8; -fx-font-size: 13px;
                                   -fx-alignment: CENTER_LEFT; -fx-padding: 12 16; -fx-background-radius: 10px; -fx-cursor: hand;"/>

                    <!-- ══ COMMANDES ══ -->
                    <Label text="COMMANDES"
                           style="-fx-font-size: 9px; -fx-font-weight: bold; -fx-text-fill: #3a5070; -fx-padding: 10 8 4 8;"/>
                    <Button fx:id="btnCommandes" text="🛍️   Mes Commandes" maxWidth="Infinity" onAction="#showCommandes"
                            style="-fx-background-color: transparent; -fx-text-fill: #7a9ab8; -fx-font-size: 13px;
                                   -fx-alignment: CENTER_LEFT; -fx-padding: 12 16; -fx-background-radius: 10px; -fx-cursor: hand;"/>
                    <Button fx:id="btnAjouterCommande" text="   ➕  Ajouter Commande" maxWidth="Infinity" onAction="#showAjouterCommande"
                            style="-fx-background-color: transparent; -fx-text-fill: #7a9ab8; -fx-font-size: 12px;
                                   -fx-alignment: CENTER_LEFT; -fx-padding: 10 16 10 28; -fx-background-radius: 10px; -fx-cursor: hand;"/>
                    <Button fx:id="btnAvecLivraison" text="   🚚  Avec Livraison" maxWidth="Infinity" onAction="#showAvecLivraison"
                            style="-fx-background-color: transparent; -fx-text-fill: #7a9ab8; -fx-font-size: 12px;
                                   -fx-alignment: CENTER_LEFT; -fx-padding: 10 16 10 28; -fx-background-radius: 10px; -fx-cursor: hand;"/>
                    <Button fx:id="btnCalendrier" text="   📅  Calendrier" maxWidth="Infinity" onAction="#showCalendrier"
                            style="-fx-background-color: transparent; -fx-text-fill: #7a9ab8; -fx-font-size: 12px;
                                   -fx-alignment: CENTER_LEFT; -fx-padding: 10 16 10 28; -fx-background-radius: 10px; -fx-cursor: hand;"/>
                    <Button fx:id="btnPaiement" text="   💳  Paiement" maxWidth="Infinity" onAction="#showPaiement"
                            style="-fx-background-color: transparent; -fx-text-fill: #7a9ab8; -fx-font-size: 12px;
                                   -fx-alignment: CENTER_LEFT; -fx-padding: 10 16 10 28; -fx-background-radius: 10px; -fx-cursor: hand;"/>

                    <!-- ══ COMMUNICATION ══ -->
                    <Label text="COMMUNICATION"
                           style="-fx-font-size: 9px; -fx-font-weight: bold; -fx-text-fill: #3a5070; -fx-padding: 10 8 4 8;"/>
                    <Button fx:id="btnPublications" text="📰   Publications" maxWidth="Infinity" onAction="#showPublications"
                            style="-fx-background-color: transparent; -fx-text-fill: #7a9ab8; -fx-font-size: 13px;
                                   -fx-alignment: CENTER_LEFT; -fx-padding: 12 16; -fx-background-radius: 10px; -fx-cursor: hand;"/>
                    <Button fx:id="btnFeedback" text="💬   Feedback" maxWidth="Infinity" onAction="#showFeedback"
                            style="-fx-background-color: transparent; -fx-text-fill: #7a9ab8; -fx-font-size: 13px;
                                   -fx-alignment: CENTER_LEFT; -fx-padding: 12 16; -fx-background-radius: 10px; -fx-cursor: hand;"/>

                    <!-- Zone accès refusé -->
                    <Region prefHeight="16"/>
                    <VBox spacing="6"
                          style="-fx-background-color: rgba(220,38,38,0.08); -fx-background-radius: 10px;
                                 -fx-padding: 12 14; -fx-border-color: rgba(220,38,38,0.15);
                                 -fx-border-width: 1px; -fx-border-radius: 10px;">
                        <Label text="🔒 Zone Administrateur"
                               style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #ef4444;"/>
                        <Label text="Utilisateurs, Rôles et statistiques&#10;sont réservés à l'admin."
                               style="-fx-font-size: 10px; -fx-text-fill: #64748b;" wrapText="true"/>
                    </VBox>
                </VBox>
            </ScrollPane>

            <Region style="-fx-background-color: #1a2d47; -fx-pref-height: 1px;"/>
            <HBox alignment="CENTER_LEFT" spacing="10" style="-fx-padding: 14 14; -fx-background-color: #091422;">
                <StackPane minWidth="36" minHeight="36" maxWidth="36" maxHeight="36"
                           style="-fx-background-color: #1e3a5f; -fx-background-radius: 50%;">
                    <Label fx:id="lblAvatarInitial" text="U"
                           style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                </StackPane>
                <VBox spacing="1" HBox.hgrow="ALWAYS">
                    <Label fx:id="lblUserName" text="Utilisateur" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                    <Label fx:id="lblUserRole" text="Rôle" style="-fx-font-size: 11px; -fx-text-fill: #4a6080;"/>
                </VBox>
                <Button text="⏻" onAction="#handleLogout"
                        style="-fx-background-color: rgba(220,38,38,0.15); -fx-background-radius: 8px;
                               -fx-text-fill: #ef4444; -fx-font-size: 14px; -fx-cursor: hand; -fx-padding: 6 8;"/>
            </HBox>
        </VBox>
    </left>

    <center>
        <VBox style="-fx-background-color: #f1f4f9;">
            <HBox alignment="CENTER_LEFT" spacing="16"
                  style="-fx-background-color: white; -fx-padding: 13 24;
                         -fx-border-color: #e5e9f0; -fx-border-width: 0 0 1 0;
                         -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 6, 0, 0, 2);">
                <ImageView fitWidth="90" fitHeight="38" preserveRatio="true" smooth="true">
                    <image><Image url="@/images/logo_localtrade.png"/></image>
                </ImageView>
                <Label text="›" style="-fx-font-size: 14px; -fx-text-fill: #cbd5e1;"/>
                <Label fx:id="lblPageTitle" text="Accueil"
                       style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <StackPane minWidth="36" minHeight="36" maxWidth="36" maxHeight="36"
                           style="-fx-background-color: #1e3a5f; -fx-background-radius: 50%; -fx-cursor: hand;"
                           onMouseClicked="#handleTopAvatarClick">
                    <Label fx:id="lblTopAvatar" text="U"
                           style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                    <ImageView fx:id="imgTopAvatar" visible="false" managed="false"
                               fitWidth="36" fitHeight="36" preserveRatio="false">
                        <clip><Circle centerX="18" centerY="18" radius="18"/></clip>
                    </ImageView>
                </StackPane>
            </HBox>
            <StackPane fx:id="contentArea" VBox.vgrow="ALWAYS"
                       style="-fx-background-color: #f1f4f9; -fx-padding: 24 28 24 28;"/>
        </VBox>
    </center>
</BorderPane>
