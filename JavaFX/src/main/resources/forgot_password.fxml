<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.shape.*?>
<?import javafx.geometry.Insets?>

<StackPane xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="Controller.ForgotPasswordController"
           alignment="CENTER"
           style="-fx-background-color: #060d1a;">

    <!-- ══ Arrière-plan décoratif identique au login ══ -->
    <Circle radius="380" fill="rgba(249,115,22,0.035)"
            StackPane.alignment="TOP_RIGHT" translateX="160" translateY="-140"/>
    <Circle radius="260" fill="rgba(30,58,95,0.4)"
            StackPane.alignment="BOTTOM_LEFT" translateX="-100" translateY="100"/>
    <Circle radius="140" fill="rgba(249,115,22,0.05)"
            StackPane.alignment="BOTTOM_RIGHT" translateX="80" translateY="80"/>
    <Circle radius="80" fill="rgba(16,185,129,0.04)"
            StackPane.alignment="TOP_LEFT" translateX="-20" translateY="60"/>

    <!-- ══ Carte centrée ══ -->
    <ScrollPane fitToWidth="true" maxWidth="520" maxHeight="820"
                style="-fx-background: transparent; -fx-background-color: transparent;
                       -fx-border-color: transparent; -fx-padding: 20 0;">

        <VBox spacing="0" maxWidth="500" minWidth="460"
              style="-fx-background-color: #ffffff;
                     -fx-background-radius: 24px;
                     -fx-border-color: #e2e8f0;
                     -fx-border-width: 1.5px;
                     -fx-border-radius: 24px;
                     -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.65), 48, 0, 0, 20);">

            <!-- ── Header ── -->
            <VBox alignment="CENTER" spacing="10"
                  style="-fx-padding: 32 36 28 36;
                         -fx-background-color: #f8fafc;
                         -fx-background-radius: 24 24 0 0;">

                <!-- Icône clé -->
                <StackPane maxWidth="72" maxHeight="72">
                    <Circle radius="36" fill="rgba(249,115,22,0.15)" stroke="rgba(249,115,22,0.3)" strokeWidth="1.5"/>
                    <Label text="🔑" style="-fx-font-size: 30px;"/>
                </StackPane>

                <Label text="Mot de passe oublié ?"
                       style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
                <Label text="Entrez votre email ou téléphone pour recevoir un code OTP"
                       wrapText="true" textAlignment="CENTER"
                       style="-fx-font-size: 12px; -fx-text-fill: #94a3b8; -fx-text-alignment: center;"/>
            </VBox>

            <!-- Barre orange accent -->
            <Region style="-fx-background-color: #f97316; -fx-pref-height: 3px;"/>

            <!-- ── Contenu ── -->
            <VBox spacing="20" style="-fx-padding: 28 36 32 36;">

                <!-- Feedback -->
                <Label fx:id="feedbackLabel" wrapText="true" managed="false" visible="false"
                       style="-fx-font-size: 12px; -fx-background-radius: 10px; -fx-border-radius: 10px;
                              -fx-padding: 12 16; -fx-border-width: 1px;"/>

                <!-- ══ EMAIL ══ -->
                <VBox spacing="8">
                    <Label text="Adresse email"
                           style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #64748b;
                                  -fx-padding: 0 0 0 2;"/>
                    <HBox alignment="CENTER_LEFT"
                          style="-fx-background-color: #f9fafb; -fx-background-radius: 12px;
                                 -fx-border-color: #e2e8f0; -fx-border-width: 1.5px;
                                 -fx-border-radius: 12px;">
                        <Label text="  📧  "
                               style="-fx-font-size: 15px; -fx-text-fill: #94a3b8; -fx-padding: 0 2;"/>
                        <TextField fx:id="emailField" promptText="vous@gmail.com"
                                   HBox.hgrow="ALWAYS"
                                   style="-fx-pref-height: 48px; -fx-background-color: transparent;
                                          -fx-border-color: transparent; -fx-font-size: 14px;
                                          -fx-text-fill: #1e293b; -fx-prompt-text-fill: #1e3050;
                                          -fx-padding: 12 14 12 4;"/>
                    </HBox>
                    <Button text="📧   Envoyer le code par email" onAction="#handleSendByEmail"
                            maxWidth="Infinity"
                            style="-fx-pref-height: 48px;
                                   -fx-background-color: #1e3a5f;
                                   -fx-border-color: #f97316; -fx-border-width: 1.5px;
                                   -fx-border-radius: 12px; -fx-background-radius: 12px;
                                   -fx-text-fill: #f97316; -fx-font-size: 13px; -fx-font-weight: bold;
                                   -fx-cursor: hand;"/>
                </VBox>

                <!-- ══ SÉPARATEUR OU ══ -->
                <HBox alignment="CENTER" spacing="12">
                    <Region style="-fx-background-color: #e5e7eb; -fx-pref-height: 1px;" HBox.hgrow="ALWAYS"/>
                    <Label text="OU" style="-fx-text-fill: #94a3b8; -fx-font-size: 12px;"/>
                    <Region style="-fx-background-color: #e5e7eb; -fx-pref-height: 1px;" HBox.hgrow="ALWAYS"/>
                </HBox>

                <!-- ══ TÉLÉPHONE ══ -->
                <VBox spacing="8">
                    <Label text="Numéro de téléphone"
                           style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #64748b;
                                  -fx-padding: 0 0 0 2;"/>
                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <!-- Indicatif +216 -->
                        <HBox alignment="CENTER" spacing="6" minWidth="96" maxWidth="96"
                              style="-fx-pref-height: 48px;
                                     -fx-background-color: #f9fafb;
                                     -fx-border-color: #e2e8f0; -fx-border-width: 1.5px;
                                     -fx-border-radius: 12px; -fx-background-radius: 12px;
                                     -fx-padding: 0 10;">
                            <Label text="🇹🇳" style="-fx-font-size: 14px;"/>
                            <Label text="+216"
                                   style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #64748b;"/>
                        </HBox>
                        <HBox alignment="CENTER_LEFT" HBox.hgrow="ALWAYS"
                              style="-fx-background-color: #f9fafb; -fx-background-radius: 12px;
                                     -fx-border-color: #e2e8f0; -fx-border-width: 1.5px;
                                     -fx-border-radius: 12px;">
                            <Label text="  📱  "
                                   style="-fx-font-size: 15px; -fx-text-fill: #94a3b8; -fx-padding: 0 2;"/>
                            <TextField fx:id="phoneField" promptText="XX XXX XXX"
                                       HBox.hgrow="ALWAYS"
                                       style="-fx-pref-height: 48px; -fx-background-color: transparent;
                                              -fx-border-color: transparent; -fx-font-size: 14px;
                                              -fx-text-fill: #1e293b; -fx-prompt-text-fill: #1e3050;
                                              -fx-padding: 12 14 12 4;"/>
                        </HBox>
                    </HBox>
                    <Button text="📱   Envoyer le code par SMS  (Twilio)" onAction="#handleSendBySms"
                            maxWidth="Infinity"
                            style="-fx-pref-height: 48px;
                                   -fx-background-color: rgba(16,185,129,0.1);
                                   -fx-border-color: #10b981; -fx-border-width: 1.5px;
                                   -fx-border-radius: 12px; -fx-background-radius: 12px;
                                   -fx-text-fill: #10b981; -fx-font-size: 13px; -fx-font-weight: bold;
                                   -fx-cursor: hand;"/>
                </VBox>

                <!-- ══ SECTION CODE OTP (cachée) ══ -->
                <VBox fx:id="codeSection" spacing="12" managed="false" visible="false"
                      style="-fx-background-color: #f8fafc; -fx-background-radius: 14px;
                             -fx-border-color: #fed7aa; -fx-border-width: 1px;
                             -fx-border-radius: 14px; -fx-padding: 18 20;">

                    <VBox spacing="3">
                        <Label text="ÉTAPE 2 — Entrez le code reçu"
                               style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
                        <Label fx:id="codeSentToLabel" text="Code envoyé à votre contact"
                               style="-fx-font-size: 11px; -fx-text-fill: #94a3b8;"/>
                    </VBox>

                    <HBox alignment="CENTER_LEFT"
                          style="-fx-background-color: #f9fafb; -fx-background-radius: 12px;
                                 -fx-border-color: #f97316; -fx-border-width: 2px;
                                 -fx-border-radius: 12px;">
                        <Label text="  🔢  "
                               style="-fx-font-size: 15px; -fx-text-fill: #f97316; -fx-padding: 0 2;"/>
                        <TextField fx:id="codeField" promptText="_ _ _ _ _ _"
                                   HBox.hgrow="ALWAYS"
                                   style="-fx-pref-height: 56px; -fx-background-color: transparent;
                                          -fx-border-color: transparent;
                                          -fx-font-size: 26px; -fx-font-weight: bold;
                                          -fx-text-fill: #f97316; -fx-prompt-text-fill: #d1d5db;
                                          -fx-alignment: CENTER; -fx-padding: 0 14 0 4;"/>
                    </HBox>

                    <HBox alignment="CENTER_LEFT" spacing="8">
                        <Label text="⏱️" style="-fx-font-size: 11px;"/>
                        <Label text="Expire dans 10 minutes"
                               style="-fx-font-size: 11px; -fx-text-fill: #94a3b8; -fx-font-style: italic;"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Button text="Renvoyer" onAction="#handleResendCode"
                                style="-fx-background-color: transparent; -fx-text-fill: #64748b;
                                       -fx-font-size: 11px; -fx-cursor: hand; -fx-underline: true; -fx-padding: 0;"/>
                    </HBox>

                    <Button text="Vérifier le code  ✓" onAction="#handleVerifyCode"
                            maxWidth="Infinity"
                            style="-fx-pref-height: 46px; -fx-background-color: #f97316; -fx-text-fill: #1e293b;
                                   -fx-font-size: 13px; -fx-font-weight: bold;
                                   -fx-background-radius: 12px; -fx-cursor: hand;
                                   -fx-effect: dropshadow(gaussian, rgba(249,115,22,0.55), 18, 0, 0, 7);"/>
                </VBox>

                <!-- ══ SECTION NOUVEAU MDP (cachée) ══ -->
                <VBox fx:id="passwordSection" spacing="12" managed="false" visible="false"
                      style="-fx-background-color: #f8fafc; -fx-background-radius: 14px;
                             -fx-border-color: #bbf7d0; -fx-border-width: 1px;
                             -fx-border-radius: 14px; -fx-padding: 18 20;">

                    <VBox spacing="3">
                        <Label text="ÉTAPE 3 — Nouveau mot de passe"
                               style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
                        <Label text="Min 8 caractères · 1 majuscule · 1 chiffre"
                               style="-fx-font-size: 11px; -fx-text-fill: #94a3b8;"/>
                    </VBox>

                    <StackPane>
                        <HBox alignment="CENTER_LEFT"
                              style="-fx-background-color: #f9fafb; -fx-background-radius: 12px;
                                     -fx-border-color: #10b981; -fx-border-width: 1.5px;
                                     -fx-border-radius: 12px;">
                            <Label text="  🔒  "
                                   style="-fx-font-size: 15px; -fx-text-fill: #94a3b8; -fx-padding: 0 2;"/>
                            <TextField fx:id="newPasswordField" promptText="Nouveau mot de passe"
                                       HBox.hgrow="ALWAYS"
                                       style="-fx-pref-height: 48px; -fx-background-color: transparent;
                                              -fx-border-color: transparent; -fx-font-size: 14px;
                                              -fx-text-fill: #1e293b; -fx-prompt-text-fill: #1e3050;
                                              -fx-padding: 12 48 12 4;"/>
                            <PasswordField fx:id="newPasswordFieldMasked" promptText="Nouveau mot de passe"
                                           visible="false" managed="false"
                                           HBox.hgrow="ALWAYS"
                                           style="-fx-pref-height: 48px; -fx-background-color: transparent;
                                                  -fx-border-color: transparent; -fx-font-size: 14px;
                                                  -fx-text-fill: #1e293b; -fx-prompt-text-fill: #1e3050;
                                                  -fx-padding: 12 48 12 4;"/>
                        </HBox>
                        <Button fx:id="toggleNewPwdBtn" text="👁️" onAction="#toggleNewPassword"
                                style="-fx-background-color: transparent; -fx-cursor: hand;
                                       -fx-font-size: 15px; -fx-padding: 6 10;"
                                StackPane.alignment="CENTER_RIGHT">
                            <StackPane.margin><Insets right="6"/></StackPane.margin>
                        </Button>
                    </StackPane>

                    <Button text="Réinitialiser le mot de passe  →" onAction="#handleResetPassword"
                            maxWidth="Infinity"
                            style="-fx-pref-height: 50px; -fx-background-color: #10b981; -fx-text-fill: #1e293b;
                                   -fx-font-size: 14px; -fx-font-weight: bold;
                                   -fx-background-radius: 12px; -fx-cursor: hand;
                                   -fx-effect: dropshadow(gaussian, rgba(16,185,129,0.55), 18, 0, 0, 7);"/>
                </VBox>

                <!-- Retour login -->
                <HBox alignment="CENTER">
                    <Button text="← Retour à la connexion" onAction="#handleBackToLogin"
                            style="-fx-background-color: transparent; -fx-text-fill: #64748b;
                                   -fx-font-size: 12px; -fx-cursor: hand; -fx-padding: 0; -fx-underline: true;"/>
                </HBox>

            </VBox>
        </VBox>
    </ScrollPane>

</StackPane>

