<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.shape.*?>
<?import javafx.geometry.Insets?>

<StackPane xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="Controller.LoginController"
           style="-fx-background-color: #060d1a;">

    <!-- ══ Arrière-plan décoratif ══ -->
    <Circle radius="380" fill="rgba(249,115,22,0.035)"
            StackPane.alignment="TOP_RIGHT" translateX="160" translateY="-140"/>
    <Circle radius="260" fill="rgba(30,58,95,0.4)"
            StackPane.alignment="BOTTOM_LEFT" translateX="-100" translateY="100"/>
    <Circle radius="140" fill="rgba(249,115,22,0.05)"
            StackPane.alignment="BOTTOM_RIGHT" translateX="80" translateY="80"/>
    <Circle radius="80"  fill="rgba(16,185,129,0.04)"
            StackPane.alignment="TOP_LEFT" translateX="-20" translateY="60"/>

    <HBox>

        <!-- ══════════════════════════════════════════
             PANNEAU GAUCHE — Branding LocalTrade
        ══════════════════════════════════════════ -->
        <VBox alignment="CENTER" spacing="36" prefWidth="520"
              style="-fx-padding: 70 56 70 70;">

            <!-- Logo -->
            <ImageView fitWidth="240" fitHeight="120" preserveRatio="true" smooth="true">
                <image><Image url="@/images/logo_localtrade.png"/></image>
            </ImageView>

            <!-- Headline -->
            <VBox spacing="10">
                <Label text="La marketplace qui"
                       style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                <Label text="connecte les talents locaux"
                       style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #f97316;"/>
                <Label text="Gérez produits, commandes, livraisons\net feedbacks depuis un seul espace."
                       wrapText="true"
                       style="-fx-font-size: 14px; -fx-text-fill: #3d5a7a; -fx-line-spacing: 3;"/>
            </VBox>

            <!-- Ligne déco -->
            <HBox alignment="CENTER_LEFT" spacing="0">
                <Region style="-fx-background-color: #f97316; -fx-pref-height: 2px; -fx-pref-width: 40px; -fx-background-radius: 1px;"/>
                <Region style="-fx-background-color: #1e3a5f; -fx-pref-height: 2px;" HBox.hgrow="ALWAYS"/>
            </HBox>

            <!-- Feature cards -->
            <VBox spacing="16">
                <!-- Feature 1 -->
                <HBox alignment="CENTER_LEFT" spacing="16"
                      style="-fx-background-color: rgba(249,115,22,0.06); -fx-background-radius: 14px;
                             -fx-border-color: rgba(249,115,22,0.12); -fx-border-width: 1px;
                             -fx-border-radius: 14px; -fx-padding: 14 18;">
                    <StackPane minWidth="42" minHeight="42" maxWidth="42" maxHeight="42"
                               style="-fx-background-color: rgba(249,115,22,0.18); -fx-background-radius: 12px;">
                        <Label text="🏪" style="-fx-font-size: 18px;"/>
                    </StackPane>
                    <VBox spacing="3">
                        <Label text="Gestion des marchands locaux"
                               style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                        <Label text="Produits, fournisseurs et catalogue complet"
                               style="-fx-font-size: 11px; -fx-text-fill: #3d5a7a;"/>
                    </VBox>
                </HBox>

                <!-- Feature 2 -->
                <HBox alignment="CENTER_LEFT" spacing="16"
                      style="-fx-background-color: rgba(30,58,95,0.3); -fx-background-radius: 14px;
                             -fx-border-color: rgba(30,58,95,0.5); -fx-border-width: 1px;
                             -fx-border-radius: 14px; -fx-padding: 14 18;">
                    <StackPane minWidth="42" minHeight="42" maxWidth="42" maxHeight="42"
                               style="-fx-background-color: rgba(30,58,95,0.5); -fx-background-radius: 12px;">
                        <Label text="🚚" style="-fx-font-size: 18px;"/>
                    </StackPane>
                    <VBox spacing="3">
                        <Label text="Suivi des livraisons en temps réel"
                               style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                        <Label text="Commandes et statuts actualisés"
                               style="-fx-font-size: 11px; -fx-text-fill: #3d5a7a;"/>
                    </VBox>
                </HBox>

                <!-- Feature 3 -->
                <HBox alignment="CENTER_LEFT" spacing="16"
                      style="-fx-background-color: rgba(139,92,246,0.07); -fx-background-radius: 14px;
                             -fx-border-color: rgba(139,92,246,0.12); -fx-border-width: 1px;
                             -fx-border-radius: 14px; -fx-padding: 14 18;">
                    <StackPane minWidth="42" minHeight="42" maxWidth="42" maxHeight="42"
                               style="-fx-background-color: rgba(139,92,246,0.15); -fx-background-radius: 12px;">
                        <Label text="💬" style="-fx-font-size: 18px;"/>
                    </StackPane>
                    <VBox spacing="3">
                        <Label text="Feedbacks &amp; satisfaction clients"
                               style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                        <Label text="Analysez et améliorez votre service"
                               style="-fx-font-size: 11px; -fx-text-fill: #3d5a7a;"/>
                    </VBox>
                </HBox>
            </VBox>

            <!-- Badge sécurité bas -->
            <HBox alignment="CENTER" spacing="8">
                <Label text="🔒" style="-fx-font-size: 12px;"/>
                <Label text="Connexion sécurisée · LocalTrade © 2025"
                       style="-fx-font-size: 11px; -fx-text-fill: #1e3050;"/>
            </HBox>
        </VBox>

        <!-- ══════════════════════════════════════════
             PANNEAU DROIT — Formulaire connexion
        ══════════════════════════════════════════ -->
        <StackPane HBox.hgrow="ALWAYS" alignment="CENTER"
                   style="-fx-padding: 40 60 40 30;">

            <VBox spacing="0" maxWidth="420"
                  style="-fx-background-color: #ffffff; -fx-background-radius: 24px;
                         -fx-border-color: #e2e8f0; -fx-border-width: 1.5px; -fx-border-radius: 24px;
                         -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.65), 48, 0, 0, 20);">

                <!-- ── Header ── -->
                <VBox alignment="CENTER" spacing="8"
                      style="-fx-padding: 32 36 28 36; -fx-background-color: #f8fafc;
                             -fx-background-radius: 24 24 0 0;">
                    <ImageView fitWidth="130" fitHeight="56" preserveRatio="true" smooth="true">
                        <image><Image url="@/images/logo_localtrade.png"/></image>
                    </ImageView>
                    <Label text="Connexion"
                           style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
                    <Label text="Accédez à votre espace"
                           style="-fx-font-size: 12px; -fx-text-fill: #94a3b8;"/>
                </VBox>

                <!-- Barre orange accent -->
                <Region style="-fx-background-color: #f97316; -fx-pref-height: 3px;"/>

                <!-- ── Formulaire ── -->
                <VBox spacing="20" style="-fx-padding: 30 36 34 36;">

                    <!-- Erreur -->
                    <Label fx:id="errorLabel" wrapText="true" managed="false" visible="false"
                           style="-fx-text-fill: #dc2626; -fx-font-size: 12px;
                                  -fx-background-color: #fef2f2;
                                  -fx-border-color: #fecaca; -fx-border-width: 1px;
                                  -fx-background-radius: 10px; -fx-border-radius: 10px;
                                  -fx-padding: 12 16;"/>

                    <!-- Email -->
                    <VBox spacing="8">
                        <Label text="Adresse email"
                               style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #374151;
                                      -fx-padding: 0 0 0 2;"/>
                        <HBox alignment="CENTER_LEFT"
                              style="-fx-background-color: #f9fafb; -fx-background-radius: 12px;
                                     -fx-border-color: #1a2d47; -fx-border-width: 1.5px;
                                     -fx-border-radius: 12px;">
                            <Label text="  📧  "
                                   style="-fx-font-size: 15px; -fx-text-fill: #9ca3af; -fx-padding: 0 2;"/>
                            <TextField fx:id="emailField" promptText="vous@gmail.com"
                                       HBox.hgrow="ALWAYS"
                                       style="-fx-pref-height: 48px; -fx-background-color: transparent;
                                              -fx-border-color: transparent; -fx-font-size: 14px;
                                              -fx-text-fill: #1e293b; -fx-prompt-text-fill: #9ca3af;
                                              -fx-padding: 12 14 12 4;"/>
                        </HBox>
                    </VBox>

                    <!-- Mot de passe -->
                    <VBox spacing="8">
                        <Label text="Mot de passe"
                               style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #374151;
                                      -fx-padding: 0 0 0 2;"/>
                        <StackPane>
                            <HBox alignment="CENTER_LEFT"
                                  style="-fx-background-color: #f9fafb; -fx-background-radius: 12px;
                                         -fx-border-color: #1a2d47; -fx-border-width: 1.5px;
                                         -fx-border-radius: 12px;">
                                <Label text="  🔒  "
                                       style="-fx-font-size: 15px; -fx-text-fill: #9ca3af; -fx-padding: 0 2;"/>
                                <PasswordField fx:id="passwordField" promptText="••••••••"
                                               HBox.hgrow="ALWAYS"
                                               style="-fx-pref-height: 48px; -fx-background-color: transparent;
                                                      -fx-border-color: transparent; -fx-font-size: 14px;
                                                      -fx-text-fill: #1e293b; -fx-prompt-text-fill: #9ca3af;
                                                      -fx-padding: 12 48 12 4;"/>
                                <TextField fx:id="visiblePasswordField" promptText="••••••••"
                                           visible="false" managed="false"
                                           HBox.hgrow="ALWAYS"
                                           style="-fx-pref-height: 48px; -fx-background-color: transparent;
                                                  -fx-border-color: transparent; -fx-font-size: 14px;
                                                  -fx-text-fill: #1e293b; -fx-prompt-text-fill: #9ca3af;
                                                  -fx-padding: 12 48 12 4;"/>
                            </HBox>
                            <Button fx:id="togglePasswordButton" text="👁️"
                                    onAction="#togglePasswordVisibility"
                                    style="-fx-background-color: transparent; -fx-cursor: hand;
                                           -fx-font-size: 15px; -fx-padding: 6 10;"
                                    StackPane.alignment="CENTER_RIGHT">
                                <StackPane.margin><Insets right="6"/></StackPane.margin>
                            </Button>
                        </StackPane>
                    </VBox>

                    <!-- Mot de passe oublié -->
                    <HBox alignment="CENTER_RIGHT">
                        <Button text="Mot de passe oublié ?" onAction="#handleForgotPassword"
                                style="-fx-background-color: transparent; -fx-text-fill: #4a6a8a;
                                       -fx-font-size: 12px; -fx-cursor: hand; -fx-padding: 0;
                                       -fx-underline: true;"/>
                    </HBox>

                    <!-- Bouton Se connecter -->
                    <Button text="Se connecter  →" onAction="#handleLogin"
                            maxWidth="Infinity"
                            style="-fx-pref-height: 52px; -fx-font-size: 15px; -fx-font-weight: bold;
                                   -fx-background-color: #f97316; -fx-text-fill: white;
                                   -fx-background-radius: 13px; -fx-cursor: hand;
                                   -fx-effect: dropshadow(gaussian, rgba(249,115,22,0.55), 18, 0, 0, 7);">
                        <VBox.margin><Insets top="6"/></VBox.margin>
                    </Button>

                    <!-- Séparateur -->
                    <HBox alignment="CENTER" spacing="12">
                        <Region style="-fx-background-color: #e5e7eb; -fx-pref-height: 1px;" HBox.hgrow="ALWAYS"/>
                        <Label text="ou" style="-fx-text-fill: #9ca3af; -fx-font-size: 12px;"/>
                        <Region style="-fx-background-color: #e5e7eb; -fx-pref-height: 1px;" HBox.hgrow="ALWAYS"/>
                    </HBox>

                    <!-- Lien inscription -->
                    <HBox alignment="CENTER" spacing="6">
                        <Label text="Pas encore de compte ?"
                               style="-fx-text-fill: #6b7280; -fx-font-size: 13px;"/>
                        <Button text="Créer un compte →" onAction="#handleGoToRegister"
                                style="-fx-background-color: transparent; -fx-text-fill: #f97316;
                                       -fx-font-weight: bold; -fx-font-size: 13px;
                                       -fx-cursor: hand; -fx-padding: 0; -fx-underline: true;"/>
                    </HBox>

                </VBox>
            </VBox>
        </StackPane>
    </HBox>
</StackPane>
