{% extends 'base.html.twig' %}

{% block title %}New Order{% endblock %}

{% block breadcrumb %}
<li class="breadcrumb-item"><a href="{{ path('app_commande_index') }}">Orders</a></li>
<li class="breadcrumb-item active">New Order</li>
{% endblock %}

{% block body %}
<div class="page-header">
    <h1><i class="bi bi-plus-circle me-2"></i>Create New Order</h1>
    <p>Fill in the order details</p>
</div>

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card">
            <div class="card-header">
                <h5 class="mb-0"><i class="bi bi-cart3 me-2"></i>Order Information</h5>
            </div>
            <div class="card-body">
                <form method="post">
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label for="client" class="form-label">Client Name <span class="text-danger">*</span></label>
                            <input type="text" name="client" id="client" class="form-control" required placeholder="Enter client name">
                        </div>
                        
                        <div class="col-md-6 mb-3">
                            <label for="dateCommande" class="form-label">Order Date</label>
                            <input type="date" name="dateCommande" id="dateCommande" class="form-control" value="{{ "now"|date('Y-m-d') }}">
                        </div>
                    </div>
                    
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label for="montantTotal" class="form-label">Total Amount (TND) <span class="text-danger">*</span></label>
                            <div class="input-group">
                                <span class="input-group-text">TND</span>
                                <input type="number" name="montantTotal" id="montantTotal" class="form-control" step="0.01" min="0" required placeholder="0.00">
                            </div>
                        </div>
                        
                        <div class="col-md-6 mb-3">
                            <label for="statut" class="form-label">Status</label>
                            <select name="statut" id="statut" class="form-select">
                                <option value="En attente">En attente</option>
                                <option value="Confirmee">Confirmee</option>
                                <option value="Annulee">Annulee</option>
                            </select>
                        </div>
                    </div>
                    
                    <div class="mb-4">
                        <label for="adresseLivraison" class="form-label">Delivery Address <span class="text-danger">*</span></label>
                        <textarea name="adresseLivraison" id="adresseLivraison" class="form-control" rows="3" required placeholder="Enter complete delivery address"></textarea>
                    </div>
                    
                    <hr class="my-4">
                    
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-check-lg me-1"></i> Create Order
                        </button>
                        <a href="{{ path('app_commande_index') }}" class="btn btn-outline-secondary">
                            <i class="bi bi-x-lg me-1"></i> Cancel
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
{% endblock %}
