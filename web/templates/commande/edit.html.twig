{% extends 'base.html.twig' %}

{% block title %}Edit Order #{{ commande.numeroCommande }}{% endblock %}

{% block breadcrumb %}
<li class="breadcrumb-item"><a href="{{ path('app_commande_index') }}">Orders</a></li>
<li class="breadcrumb-item"><a href="{{ path('app_commande_show', {'id': commande.idCommande}) }}">Order #{{ commande.numeroCommande }}</a></li>
<li class="breadcrumb-item active">Edit</li>
{% endblock %}

{% block body %}
<div class="page-header">
    <h1><i class="bi bi-pencil me-2"></i>Edit Order</h1>
    <p>Update order <strong>#{{ commande.numeroCommande }}</strong></p>
</div>

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card">
            <div class="card-header">
                <h5 class="mb-0"><i class="bi bi-cart3 me-2"></i>Order Information</h5>
            </div>
            <div class="card-body">
                <form method="post">
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label for="client" class="form-label">Client Name <span class="text-danger">*</span></label>
                            <input type="text" name="client" id="client" class="form-control" value="{{ commande.client }}" required>
                        </div>
                        
                        <div class="col-md-6 mb-3">
                            <label for="montantTotal" class="form-label">Total Amount (TND) <span class="text-danger">*</span></label>
                            <div class="input-group">
                                <span class="input-group-text">TND</span>
                                <input type="number" name="montantTotal" id="montantTotal" class="form-control" step="0.01" min="0" value="{{ commande.montantTotal }}" required>
                            </div>
                        </div>
                    </div>
                    
                    <div class="mb-3">
                        <label for="adresseLivraison" class="form-label">Delivery Address <span class="text-danger">*</span></label>
                        <textarea name="adresseLivraison" id="adresseLivraison" class="form-control" rows="3" required>{{ commande.adresseLivraison }}</textarea>
                    </div>
                    
                    <div class="mb-4">
                        <label for="statut" class="form-label">Status</label>
                        <select name="statut" id="statut" class="form-select">
                            <option value="En attente" {% if commande.statut == 'En attente' %}selected{% endif %}>En attente</option>
                            <option value="Confirmee" {% if commande.statut == 'Confirmee' %}selected{% endif %}>Confirmee</option>
                            <option value="Annulee" {% if commande.statut == 'Annulee' %}selected{% endif %}>Annulee</option>
                        </select>
                    </div>
                    
                    <hr class="my-4">
                    
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-check-lg me-1"></i> Update Order
                        </button>
                        <a href="{{ path('app_commande_show', {'id': commande.idCommande}) }}" class="btn btn-outline-secondary">
                            <i class="bi bi-x-lg me-1"></i> Cancel
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
{% endblock %}
