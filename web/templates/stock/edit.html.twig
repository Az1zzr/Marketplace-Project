{% extends 'base.html.twig' %}

{% block title %}Edit Stock{% endblock %}

{% block breadcrumb %}
<li class="breadcrumb-item"><a href="{{ path('app_stock_index') }}">Stock</a></li>
<li class="breadcrumb-item active">Edit</li>
{% endblock %}

{% block body %}
<div class="page-header">
    <h1><i class="bi bi-pencil me-2"></i>Edit Stock Entry</h1>
    <p>Update stock information</p>
</div>

<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="card">
            <div class="card-header">
                <h5 class="mb-0"><i class="bi bi-boxes me-2"></i>Stock Information</h5>
            </div>
            <div class="card-body">
                <form method="post">
                    <div class="mb-3">
                        <label for="produit" class="form-label">Product <span class="text-danger">*</span></label>
                        <select name="produit" id="produit" class="form-select" required>
                            <option value="">-- Select Product --</option>
                            {% for produit in produits %}
                            <option value="{{ produit.id }}" {% if stock.produit and stock.produit.id == produit.id %}selected{% endif %}>{{ produit.nomProduit }}</option>
                            {% endfor %}
                        </select>
                    </div>

                    <div class="mb-4">
                        <label for="quantite" class="form-label">Available Quantity <span class="text-danger">*</span></label>
                        <input type="number" name="quantite" id="quantite" class="form-control" min="0" value="{{ stock.quantite }}" required>
                    </div>

                    <hr class="my-4">

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-check-lg me-1"></i> Update Stock
                        </button>
                        <a href="{{ path('app_stock_index') }}" class="btn btn-outline-secondary">
                            <i class="bi bi-x-lg me-1"></i> Cancel
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
{% endblock %}
