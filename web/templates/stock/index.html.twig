{% extends 'base.html.twig' %}

{% block title %}Stock Management{% endblock %}

{% block breadcrumb %}
<li class="breadcrumb-item active">Stock</li>
{% endblock %}

{% block body %}
<div class="page-header d-flex justify-content-between align-items-center">
    <div>
        <h1><i class="bi bi-boxes me-2"></i>Stock Management</h1>
        <p>Monitor and manage product inventory</p>
    </div>
    <a href="{{ path('app_stock_new') }}" class="btn btn-primary">
        <i class="bi bi-plus-lg me-1"></i> Add Stock Entry
    </a>
</div>

{% if stocks is empty %}
<div class="card">
    <div class="card-body text-center py-5">
        <i class="bi bi-boxes" style="font-size: 3rem; color: #94a3b8;"></i>
        <h5 class="mt-3 text-muted">No stock entries found</h5>
        <p class="text-muted">Add stock entries to track product inventory.</p>
        <a href="{{ path('app_stock_new') }}" class="btn btn-primary mt-2">
            <i class="bi bi-plus-lg me-1"></i> Add Stock Entry
        </a>
    </div>
</div>
{% else %}
<div class="card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th>Product</th>
                        <th>Available</th>
                        <th>Status</th>
                        <th>Last Updated</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                {% for stock in stocks %}
                    <tr>
                        <td>
                            <div class="d-flex align-items-center">
                                {% if stock.produit and stock.produit.imageURL %}
                                <img src="{{ stock.produit.imageURL }}" class="rounded me-2" alt="{{ stock.produit.nomProduit }}" style="width: 50px; height: 50px; object-fit: cover;">
                                {% else %}
                                <div class="bg-light rounded me-2 d-flex align-items-center justify-content-center" style="width: 50px; height: 50px;">
                                    <i class="bi bi-box-seam text-secondary"></i>
                                </div>
                                {% endif %}
                                <div>
                                    {% if stock.produit %}
                                    <div class="fw-medium">{{ stock.produit.nomProduit }}</div>
                                    <small class="text-muted">ID: {{ stock.produit.id }}</small>
                                    {% else %}
                                    <span class="text-muted">No product assigned</span>
                                    {% endif %}
                                </div>
                            </div>
                        </td>
                        <td>
                            <span class="h5 mb-0">{{ stock.quantite }}</span>
                            <span class="text-muted small">units</span>
                        </td>
                        <td>
                            {% if stock.quantite < 10 %}
                            <span class="badge bg-danger"><i class="bi bi-exclamation-circle me-1"></i>Low Stock</span>
                            {% elseif stock.quantite < 50 %}
                            <span class="badge bg-warning text-dark"><i class="bi bi-exclamation-triangle me-1"></i>Medium</span>
                            {% else %}
                            <span class="badge bg-success"><i class="bi bi-check-circle me-1"></i>Good</span>
                            {% endif %}
                        </td>
                        <td class="text-muted">
                            <small>{{ "now"|date('Y-m-d') }}</small>
                        </td>
                        <td>
                            <div class="btn-group" role="group">
                                <a href="{{ path('app_stock_edit', {'id': stock.id}) }}" class="btn btn-outline-primary btn-sm">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <form action="{{ path('app_stock_delete', {'id': stock.id}) }}" method="post" class="d-inline" onsubmit="return confirm('Delete this stock entry?');">
                                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ stock.id) }}">
                                    <button type="submit" class="btn btn-outline-danger btn-sm">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>
{% endif %}
{% endblock %}
