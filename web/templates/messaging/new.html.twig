{% extends 'base.html.twig' %}

{% block title %}New Conversation{% endblock %}

{% block breadcrumb %}
<li class="breadcrumb-item"><a href="{{ path('app_messaging_index') }}">Messages</a></li>
<li class="breadcrumb-item active" aria-current="page">New Conversation</li>
{% endblock %}

{% block body %}
<div class="page-header d-flex justify-content-between align-items-center flex-wrap gap-3">
    <div>
        <h1><i class="bi bi-person-lines-fill me-2"></i>New Conversation</h1>
        <p>Select a fournisseur to start a private conversation.</p>
    </div>
    <a href="{{ path('app_messaging_index') }}" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left me-1"></i>Back To Messages
    </a>
</div>

<div class="card mb-4">
    <div class="card-body">
        <form method="get" class="row g-3 align-items-end" novalidate>
            <div class="col-md-8">
                <label for="search" class="form-label">Search fournisseurs</label>
                <input type="text" name="search" id="search" class="form-control" value="{{ search }}" placeholder="Search by name or email...">
            </div>
            <div class="col-md-4 d-flex gap-2">
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-search me-1"></i>Apply
                </button>
                <a href="{{ path('app_messaging_new') }}" class="btn btn-outline-secondary">
                    <i class="bi bi-x-lg me-1"></i>Reset
                </a>
            </div>
        </form>
    </div>
</div>

{% if suppliers is empty %}
<div class="card">
    <div class="card-body text-center py-5">
        <i class="bi bi-shop" style="font-size: 3rem; color: #94a3b8;"></i>
        <h5 class="mt-3 text-muted">No fournisseurs found</h5>
        <p class="text-muted mb-0">Try another search or come back after suppliers publish products.</p>
    </div>
</div>
{% else %}
<div class="row g-4">
    {% for supplier in suppliers %}
    <div class="col-md-6 col-xl-4">
        <div class="card h-100">
            <div class="card-body d-flex flex-column">
                <div class="d-flex align-items-center gap-3 mb-3">
                    {% if supplier.photoPath %}
                    <img src="{{ supplier.photoPath }}" alt="{{ supplier.nomComplet }}" class="user-avatar-image">
                    {% else %}
                    <div class="user-avatar">{{ supplier.prenom|first }}{{ supplier.nom|first }}</div>
                    {% endif %}
                    <div>
                        <div class="fw-semibold">{{ supplier.nomComplet }}</div>
                        <div class="text-muted small">{{ supplier.roleDisplayName }}</div>
                    </div>
                </div>

                <div class="mb-3 text-muted small">
                    <div><i class="bi bi-envelope me-2"></i>{{ supplier.email }}</div>
                    <div class="mt-2"><i class="bi bi-telephone me-2"></i>{{ supplier.telephone ?: 'No phone number available' }}</div>
                </div>

                <div class="mt-auto d-flex gap-2 flex-wrap">
                    {% set existingConversationId = existingConversationIds[supplier.id] ?? null %}
                    {% if existingConversationId %}
                    <a href="{{ path('app_messaging_show', {'id': existingConversationId}) }}" class="btn btn-outline-secondary">
                        <i class="bi bi-chat-left-text me-1"></i>Open Conversation
                    </a>
                    {% else %}
                    <form action="{{ path('app_messaging_start', {'fournisseurId': supplier.id}) }}" method="post" novalidate>
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-chat-dots me-1"></i>Start Conversation
                        </button>
                    </form>
                    {% endif %}
                    {% if supplier.produits is not empty %}
                    <a href="{{ path('app_produit_show', {'id': supplier.produits|first.id}) }}" class="btn btn-outline-dark">
                        <i class="bi bi-box-seam me-1"></i>View A Product
                    </a>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>
    {% endfor %}
</div>
{% endif %}
{% endblock %}
