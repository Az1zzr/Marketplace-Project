{% extends 'base.html.twig' %}

{% block title %}Nouveau mot de passe{% endblock %}

{% block auth_content %}
<style>
.np-card {
    max-width: 460px;
    margin: 0 auto;
    background: #fff;
    border-radius: 20px;
    padding: 2.5rem 2rem;
    box-shadow: 0 8px 40px rgba(0,0,0,0.10);
}
.np-icon-wrap {
    width: 72px; height: 72px;
    border-radius: 50%;
    background: #e8faf2;
    display: flex; align-items: center; justify-content: center;
    margin: 0 auto 1.1rem;
    font-size: 2rem;
}
.np-title { font-weight: 800; font-size: 1.45rem; text-align:center; color:#1e293b; margin-bottom:.3rem; }
.np-sub   { text-align:center; color:#64748b; font-size:.92rem; margin-bottom:1.4rem; }
.np-sep   { border:none; border-top:2px solid #10b981; margin:0 0 1.4rem; opacity:.5; }

.np-rules {
    display:flex; align-items:center; gap:10px;
    background:#f0fdf8; border:1.5px solid #a7f3d0;
    border-radius:12px; padding:11px 15px;
    margin-bottom:1.3rem; font-size:.85rem; color:#065f46; font-weight:600;
}
.np-rules i { color:#10b981; font-size:1rem; }

.np-label { font-weight:600; font-size:.9rem; color:#374151; margin-bottom:.45rem; display:block; }

.np-input-wrap {
    display:flex; align-items:center;
    border:1.5px solid #e2e8f0; border-radius:12px;
    background:#f8fafc; overflow:hidden;
    transition: border-color .2s, box-shadow .2s;
}
.np-input-wrap:focus-within {
    border-color:#10b981;
    background:#fff;
    box-shadow:0 0 0 3px rgba(16,185,129,.12);
}
.np-input-wrap.is-invalid { border-color:#ef4444; }
.np-input-wrap .icon-left {
    padding:0 13px; color:#94a3b8; font-size:1.05rem;
    display:flex; align-items:center;
}
.np-input-wrap input {
    border:none; background:transparent;
    padding:13px 10px 13px 0; flex:1;
    font-size:1rem; outline:none; color:#1e293b;
}
.np-input-wrap input::placeholder { color:#94a3b8; }
.np-input-wrap .toggle-eye {
    padding:0 13px; cursor:pointer;
    color:#94a3b8; font-size:1.05rem;
    display:flex; align-items:center;
    background:none; border:none; outline:none;
    transition:color .2s;
}
.np-input-wrap .toggle-eye:hover { color:#1e293b; }

.np-strength {
    display:flex; gap:5px; margin-top:.4rem; margin-bottom:.1rem;
}
.np-strength span {
    height:4px; flex:1; border-radius:4px;
    background:#e2e8f0; transition:background .3s;
}
.invalid-msg { color:#ef4444; font-size:.82rem; margin-top:.3rem; }

.btn-reset {
    width:100%; margin-top:1.5rem;
    background:#10b981; color:#fff;
    border:none; border-radius:12px;
    padding:14px; font-size:1rem; font-weight:700;
    cursor:pointer; transition:background .2s;
    display:flex; align-items:center; justify-content:center; gap:8px;
}
.btn-reset:hover { background:#059669; }
.np-back { text-align:center; margin-top:1.1rem; font-size:.88rem; color:#94a3b8; }
.np-back a { color:#64748b; text-decoration:none; font-weight:500; }
.np-back a:hover { color:#1e293b; }
</style>

<div class="auth-container">
<div class="np-card">

    <div class="np-icon-wrap">🔐</div>
    <div class="np-title">Nouveau mot de passe</div>
    <p class="np-sub">Choisissez un mot de passe fort et sécurisé</p>
    <hr class="np-sep">

    <div class="np-rules">
        <i class="bi bi-check-circle-fill"></i>
        Minimum 8 caractères &nbsp;·&nbsp; 1 majuscule &nbsp;·&nbsp; 1 chiffre
    </div>

    <form method="post" novalidate>

        {# New password #}
        <div class="mb-3">
            <label class="np-label" for="password">Nouveau mot de passe</label>
            <div class="np-input-wrap {% if errors.password is defined %}is-invalid{% endif %}">
                <span class="icon-left"><i class="bi bi-lock-fill"></i></span>
                <input type="password" name="password" id="password" placeholder="••••••••" autocomplete="new-password">
                <button type="button" class="toggle-eye" onclick="togglePwd('password', this)">
                    <i class="bi bi-eye"></i>
                </button>
            </div>
            <div class="np-strength" id="strengthBars">
                <span></span><span></span><span></span><span></span>
            </div>
            {% if errors.password is defined %}
                <div class="invalid-msg">{{ errors.password }}</div>
            {% endif %}
        </div>

        {# Confirm password #}
        <div class="mb-3">
            <label class="np-label" for="confirmPassword">Confirmer le mot de passe</label>
            <div class="np-input-wrap {% if errors.confirmPassword is defined %}is-invalid{% endif %}">
                <span class="icon-left"><i class="bi bi-lock-fill"></i></span>
                <input type="password" name="confirmPassword" id="confirmPassword" placeholder="••••••••" autocomplete="new-password">
                <button type="button" class="toggle-eye" onclick="togglePwd('confirmPassword', this)">
                    <i class="bi bi-eye"></i>
                </button>
            </div>
            {% if errors.confirmPassword is defined %}
                <div class="invalid-msg">{{ errors.confirmPassword }}</div>
            {% endif %}
        </div>

        <button type="submit" class="btn-reset">
            <i class="bi bi-arrow-right-circle-fill"></i> Réinitialiser le mot de passe →
        </button>
    </form>

    <div class="np-back">
        <a href="{{ path('app_login') }}">← Retour à la connexion</a>
    </div>

</div>
</div>

<script>
function togglePwd(id, btn) {
    const input = document.getElementById(id);
    const icon  = btn.querySelector('i');
    if (input.type === 'password') {
        input.type = 'text';
        icon.className = 'bi bi-eye-slash';
    } else {
        input.type = 'password';
        icon.className = 'bi bi-eye';
    }
}

document.getElementById('password').addEventListener('input', function () {
    const val = this.value;
    let score = 0;
    if (val.length >= 8)           score++;
    if (/[A-Z]/.test(val))         score++;
    if (/[0-9]/.test(val))         score++;
    if (/[^A-Za-z0-9]/.test(val))  score++;

    const colors = ['#ef4444','#f97316','#eab308','#10b981'];
    const bars = document.querySelectorAll('#strengthBars span');
    bars.forEach((bar, i) => {
        bar.style.background = i < score ? colors[score - 1] : '#e2e8f0';
    });
});
</script>
{% endblock %}
