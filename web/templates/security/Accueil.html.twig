<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>MarketPlace — Achetez &amp; Vendez en toute confiance</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --bg:#f7f8fc;
  --bg2:#ffffff;
  --teal:#0aa89f;
  --teal-light:#e6f7f6;
  --teal-mid:#b2e8e5;
  --amber:#e89b10;
  --amber-light:#fef3dc;
  --navy:#0f1c3f;
  --body:#374160;
  --muted:#7b85a0;
  --border:#e2e6f0;
  --serif:'DM Serif Display',Georgia,serif;
  --sans:'DM Sans',system-ui,sans-serif;
}
html{scroll-behavior:smooth}
body{background:var(--bg);color:var(--body);font-family:var(--sans);min-height:100vh;overflow-x:hidden}

/* ── NAVBAR ── */
nav{
  position:fixed;top:0;left:0;right:0;z-index:100;
  display:flex;align-items:center;justify-content:space-between;
  padding:1rem 3rem;
  background:rgba(247,248,252,0.92);
  backdrop-filter:blur(14px);
  border-bottom:1px solid var(--border);
}
.nav-logo{
  font-family:var(--serif);font-size:1.45rem;color:var(--navy);
  text-decoration:none;display:flex;align-items:center;gap:.4rem;
}
.nav-logo span{color:var(--teal)}
.nav-links{display:flex;align-items:center;gap:.75rem}
.btn-nav-outline{
  padding:.5rem 1.3rem;border-radius:50px;
  border:1.5px solid var(--border);background:transparent;
  color:var(--body);font-family:var(--sans);font-size:.88rem;font-weight:500;
  cursor:pointer;text-decoration:none;transition:all .2s;
}
.btn-nav-outline:hover{border-color:var(--teal);color:var(--teal)}
.btn-nav-primary{
  padding:.5rem 1.4rem;border-radius:50px;
  background:var(--teal);border:none;color:#fff;
  font-family:var(--sans);font-size:.88rem;font-weight:600;
  cursor:pointer;text-decoration:none;transition:all .2s;
}
.btn-nav-primary:hover{background:#098f87;transform:translateY(-1px)}

/* ── HERO ── */
.hero{
  min-height:100vh;display:flex;flex-direction:column;
  align-items:center;justify-content:center;
  padding:8rem 2rem 5rem;text-align:center;
  position:relative;overflow:hidden;
  background:
    radial-gradient(ellipse 60% 50% at 50% 0%,rgba(10,168,159,.09) 0%,transparent 70%),
    radial-gradient(ellipse 40% 40% at 90% 80%,rgba(232,155,16,.07) 0%,transparent 60%),
    var(--bg);
}
.hero-dots{
  position:absolute;inset:0;pointer-events:none;
  background-image:radial-gradient(circle,rgba(10,168,159,.13) 1px,transparent 1px);
  background-size:30px 30px;
  mask-image:radial-gradient(ellipse 80% 60% at 50% 50%,black 30%,transparent 100%);
}
.hero-badge{
  display:inline-flex;align-items:center;gap:.5rem;
  padding:.38rem 1.1rem;border-radius:50px;
  background:var(--teal-light);border:1px solid var(--teal-mid);
  color:var(--teal);font-size:.8rem;font-weight:600;letter-spacing:.05em;
  margin-bottom:1.8rem;animation:fadeUp .6s ease both;
}
.hero h1{
  font-family:var(--serif);font-size:clamp(2.8rem,7vw,5rem);
  line-height:1.08;color:var(--navy);font-weight:400;
  margin-bottom:1.4rem;animation:fadeUp .7s .1s ease both;
}
.hero h1 em{font-style:italic;color:var(--teal)}
.hero h1 strong{color:var(--amber);font-weight:400}
.hero-sub{
  font-size:1.1rem;color:var(--muted);max-width:520px;line-height:1.75;
  margin-bottom:2.5rem;animation:fadeUp .7s .2s ease both;
}
.hero-ctas{
  display:flex;gap:1rem;flex-wrap:wrap;justify-content:center;
  animation:fadeUp .7s .3s ease both;
}
.btn-hero-primary{
  padding:.85rem 2.2rem;border-radius:50px;
  background:var(--teal);border:none;color:#fff;
  font-family:var(--sans);font-size:.98rem;font-weight:600;
  cursor:pointer;text-decoration:none;transition:all .25s;
  box-shadow:0 4px 20px rgba(10,168,159,.25);
}
.btn-hero-primary:hover{background:#098f87;transform:translateY(-2px);box-shadow:0 8px 28px rgba(10,168,159,.32)}
.btn-hero-outline{
  padding:.85rem 2.2rem;border-radius:50px;
  background:#fff;border:1.5px solid var(--border);
  color:var(--navy);font-family:var(--sans);font-size:.98rem;font-weight:500;
  cursor:pointer;text-decoration:none;transition:all .25s;
}
.btn-hero-outline:hover{border-color:var(--teal);color:var(--teal);transform:translateY(-2px)}
.hero-scroll{
  margin-top:4rem;display:flex;flex-direction:column;align-items:center;gap:.5rem;
  color:var(--muted);font-size:.75rem;letter-spacing:.1em;text-transform:uppercase;
  animation:fadeUp .7s .5s ease both;
}
.scroll-line{width:1px;height:36px;background:linear-gradient(to bottom,var(--teal),transparent);animation:pulse 2s infinite}

/* ── STATS ── */
.stats-bar{
  background:var(--bg2);
  border-top:1px solid var(--border);border-bottom:1px solid var(--border);
  display:flex;flex-wrap:wrap;justify-content:center;
}
.stat-item{
  flex:1;min-width:150px;max-width:220px;
  text-align:center;padding:1.8rem 1.5rem;
  border-right:1px solid var(--border);
}
.stat-item:last-child{border-right:none}
.stat-num{font-family:var(--serif);font-size:2.2rem;color:var(--navy);margin-bottom:.25rem}
.stat-num span{color:var(--teal)}
.stat-desc{font-size:.8rem;color:var(--muted);letter-spacing:.03em}

/* ── ROLES ── */
.roles-section{background:#fff;padding:6rem 2rem}
.roles-inner{max-width:1080px;margin:0 auto;text-align:center}
.section-label{
  display:inline-block;font-size:.75rem;font-weight:700;
  letter-spacing:.12em;text-transform:uppercase;
  color:var(--teal);margin-bottom:.9rem;
}
.section-title{
  font-family:var(--serif);font-size:clamp(1.9rem,4vw,2.8rem);
  color:var(--navy);line-height:1.15;margin-bottom:.9rem;
}
.section-sub{font-size:1rem;color:var(--muted);line-height:1.75}
.roles-grid{
  display:grid;grid-template-columns:repeat(auto-fit,minmax(300px,1fr));
  gap:1.5rem;margin-top:3.5rem;
}
.role-card{
  border-radius:20px;padding:2.5rem 2rem;text-align:left;
  transition:all .3s;position:relative;overflow:hidden;
  border:1.5px solid var(--border);background:var(--bg);
}
.role-card::after{
  content:'';position:absolute;top:0;left:0;right:0;height:4px;border-radius:20px 20px 0 0;
}
.role-card.client::after{background:linear-gradient(90deg,var(--teal),var(--teal-mid))}
.role-card.supplier::after{background:linear-gradient(90deg,var(--amber),#fcd06f)}
.role-card:hover{border-color:transparent;transform:translateY(-5px);box-shadow:0 16px 40px rgba(15,28,63,.1)}
.role-icon{
  width:54px;height:54px;border-radius:14px;font-size:1.5rem;
  display:flex;align-items:center;justify-content:center;margin-bottom:1.4rem;
}
.role-card.client .role-icon{background:var(--teal-light)}
.role-card.supplier .role-icon{background:var(--amber-light)}
.role-card h3{font-family:var(--serif);font-size:1.65rem;margin-bottom:.7rem}
.role-card.client h3{color:var(--teal)}
.role-card.supplier h3{color:var(--amber)}
.role-card > p{color:var(--muted);font-size:.93rem;line-height:1.7;margin-bottom:1.4rem}
.feat-list{list-style:none;display:flex;flex-direction:column;gap:.55rem;margin-bottom:2rem}
.feat-list li{display:flex;align-items:center;gap:.7rem;font-size:.9rem;color:var(--body)}
.feat-list li::before{content:'';width:7px;height:7px;border-radius:50%;flex-shrink:0}
.role-card.client .feat-list li::before{background:var(--teal)}
.role-card.supplier .feat-list li::before{background:var(--amber)}
.role-cta{
  display:inline-flex;align-items:center;gap:.45rem;
  padding:.7rem 1.5rem;border-radius:50px;
  font-family:var(--sans);font-size:.9rem;font-weight:600;
  text-decoration:none;transition:all .2s;border:1.5px solid;
}
.role-card.client .role-cta{border-color:var(--teal);color:var(--teal)}
.role-card.client .role-cta:hover{background:var(--teal);color:#fff}
.role-card.supplier .role-cta{border-color:var(--amber);color:var(--amber)}
.role-card.supplier .role-cta:hover{background:var(--amber);color:#fff}

/* ── FEATURES ── */
.features-section{background:var(--bg);padding:6rem 2rem}
.features-inner{max-width:1080px;margin:0 auto}
.features-header{text-align:center;margin-bottom:3.5rem}
.features-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(210px,1fr));gap:1.2rem}
.feat-card{
  background:#fff;border:1px solid var(--border);border-radius:16px;
  padding:1.8rem 1.5rem;transition:all .3s;
}
.feat-card:hover{border-color:var(--teal-mid);transform:translateY(-3px);box-shadow:0 8px 24px rgba(10,168,159,.08)}
.feat-card-icon{
  width:44px;height:44px;border-radius:12px;font-size:1.2rem;
  display:flex;align-items:center;justify-content:center;
  margin-bottom:1rem;background:var(--teal-light);
}
.feat-card h4{font-family:var(--serif);font-size:1.1rem;color:var(--navy);margin-bottom:.45rem}
.feat-card p{font-size:.86rem;color:var(--muted);line-height:1.65}

/* ── CTA BANNER ── */
.cta-banner{
  background:linear-gradient(135deg,var(--teal) 0%,#0d9e95 50%,#0a8a84 100%);
  padding:5.5rem 2rem;text-align:center;
}
.cta-banner h2{font-family:var(--serif);font-size:clamp(2rem,4vw,3rem);color:#fff;margin-bottom:1rem}
.cta-banner p{
  color:rgba(255,255,255,.8);font-size:1.05rem;line-height:1.7;
  margin-bottom:2.5rem;max-width:520px;margin-left:auto;margin-right:auto;
}
.cta-btns{display:flex;gap:1rem;justify-content:center;flex-wrap:wrap}
.btn-cta-white{
  padding:.85rem 2.2rem;border-radius:50px;
  background:#fff;border:none;color:var(--teal);
  font-family:var(--sans);font-size:.98rem;font-weight:700;
  text-decoration:none;transition:all .25s;
}
.btn-cta-white:hover{transform:translateY(-2px);box-shadow:0 8px 24px rgba(0,0,0,.15)}
.btn-cta-outline{
  padding:.85rem 2.2rem;border-radius:50px;
  background:transparent;border:2px solid rgba(255,255,255,.5);
  color:#fff;font-family:var(--sans);font-size:.98rem;font-weight:500;
  text-decoration:none;transition:all .25s;
}
.btn-cta-outline:hover{border-color:#fff;background:rgba(255,255,255,.1);transform:translateY(-2px)}

/* ── FOOTER ── */
footer{background:var(--navy);padding:3.5rem 2rem 2rem}
.footer-inner{max-width:1080px;margin:0 auto}
.footer-top{
  display:flex;flex-wrap:wrap;gap:2rem;
  justify-content:space-between;align-items:flex-start;
  padding-bottom:2rem;
  border-bottom:1px solid rgba(255,255,255,.08);
  margin-bottom:1.5rem;
}
.footer-brand .logo{font-family:var(--serif);font-size:1.4rem;color:#fff;margin-bottom:.5rem}
.footer-brand .logo span{color:var(--teal)}
.footer-brand p{font-size:.85rem;color:rgba(255,255,255,.4);max-width:220px;line-height:1.6}
.footer-links-group h5{
  font-size:.75rem;font-weight:700;letter-spacing:.1em;text-transform:uppercase;
  color:rgba(255,255,255,.3);margin-bottom:1rem;
}
.footer-links-group a{
  display:block;font-size:.88rem;color:rgba(255,255,255,.5);
  text-decoration:none;margin-bottom:.5rem;transition:color .2s;
}
.footer-links-group a:hover{color:#fff}
footer .copy{font-size:.8rem;color:rgba(255,255,255,.25);text-align:center}

/* ── ANIMATIONS ── */
@keyframes fadeUp{from{opacity:0;transform:translateY(20px)}to{opacity:1;transform:translateY(0)}}
@keyframes pulse{0%,100%{opacity:.3;transform:scaleY(.6)}50%{opacity:1;transform:scaleY(1)}}

/* ── RESPONSIVE ── */
@media(max-width:640px){
  nav{padding:1rem 1.2rem}
  .nav-logo{font-size:1.2rem}
  .stat-item{min-width:130px;padding:1.2rem 1rem}
  .footer-top{flex-direction:column}
}
</style>
</head>
<body>

{# ════════════════════════════════════════
   NAVBAR
   ════════════════════════════════════════ #}
<nav>
  <a href="{{ path('app_home') }}" class="nav-logo">🛒 <span>Market</span>Place</a>
  <div class="nav-links">
    <a href="#roles" class="btn-nav-outline">Découvrir</a>
    <a href="{{ path('app_login') }}" class="btn-nav-outline">Se connecter</a>
    <a href="{{ path('app_register') }}" class="btn-nav-primary">Créer un compte</a>
  </div>
</nav>

{# ════════════════════════════════════════
   HERO
   ════════════════════════════════════════ #}
<section class="hero">
  <div class="hero-dots"></div>

  <div class="hero-badge">✦ La marketplace tunisienne de confiance</div>

  <h1>
    Achetez. Vendez.<br>
    <em>Livrez.</em> <strong>Grandissez.</strong>
  </h1>

  <p class="hero-sub">
    La plateforme tout-en-un pour clients et fournisseurs. Parcourez des milliers
    de produits, gérez vos commandes et suivez vos livraisons en temps réel.
  </p>

  <div class="hero-ctas">
    <a href="{{ path('app_register') }}" class="btn-hero-primary">
      Créer un compte gratuit →
    </a>
    <a href="{{ path('app_login') }}" class="btn-hero-outline">
      Se connecter
    </a>
  </div>

  <div class="hero-scroll">
    <span>Découvrir</span>
    <div class="scroll-line"></div>
  </div>
</section>

{# ════════════════════════════════════════
   STATS
   ════════════════════════════════════════ #}
<div class="stats-bar">
  <div class="stat-item">
    <div class="stat-num">12<span>k+</span></div>
    <div class="stat-desc">Produits disponibles</div>
  </div>
  <div class="stat-item">
    <div class="stat-num">3<span>k+</span></div>
    <div class="stat-desc">Clients actifs</div>
  </div>
  <div class="stat-item">
    <div class="stat-num">480<span>+</span></div>
    <div class="stat-desc">Fournisseurs</div>
  </div>
  <div class="stat-item">
    <div class="stat-num">98<span>%</span></div>
    <div class="stat-desc">Satisfaction client</div>
  </div>
</div>

{# ════════════════════════════════════════
   ROLES
   ════════════════════════════════════════ #}
<section class="roles-section" id="roles">
  <div class="roles-inner">
    <span class="section-label">Deux rôles, une plateforme</span>
    <h2 class="section-title">Rejoignez selon votre profil</h2>
    <p class="section-sub" style="max-width:480px;margin:0 auto">
      Que vous soyez acheteur ou vendeur, MarketPlace est conçu pour vous.
    </p>

    <div class="roles-grid">

      {# CLIENT #}
      <div class="role-card client">
        <div class="role-icon">🛍️</div>
        <h3>Client</h3>
        <p>
          Explorez un catalogue riche, passez des commandes en quelques clics
          et suivez vos livraisons en direct. Partagez votre expérience avec la communauté.
        </p>
        <ul class="feat-list">
          <li>Parcourir des milliers de produits</li>
          <li>Passer et gérer mes commandes</li>
          <li>Suivi de livraison en temps réel</li>
          <li>Écrire &amp; lire des feedbacks</li>
          <li>Photo de profil personnalisée</li>
        </ul>
        <a href="{{ path('app_register') }}" class="role-cta">
          Rejoindre en tant que Client →
        </a>
      </div>

      {# FOURNISSEUR #}
      <div class="role-card supplier">
        <div class="role-icon">🏭</div>
        <h3>Fournisseur</h3>
        <p>
          Publiez votre catalogue, organisez vos catégories, gérez les commandes
          et pilotez vos livraisons depuis un tableau de bord dédié.
        </p>
        <ul class="feat-list">
          <li>Ajouter &amp; gérer des produits</li>
          <li>Organiser les catégories</li>
          <li>Recevoir &amp; traiter les commandes</li>
          <li>Affecter des livreurs</li>
          <li>Répondre aux feedbacks clients</li>
        </ul>
        <a href="{{ path('app_register') }}" class="role-cta">
          Rejoindre en tant que Fournisseur →
        </a>
      </div>

    </div>
  </div>
</section>

{# ════════════════════════════════════════
   FEATURES
   ════════════════════════════════════════ #}
<section class="features-section">
  <div class="features-inner">
    <div class="features-header">
      <span class="section-label">Tout ce dont vous avez besoin</span>
      <h2 class="section-title">Une plateforme complète</h2>
      <p class="section-sub" style="max-width:480px;margin:.5rem auto 0">
        Des outils pensés pour faciliter chaque étape, de l'achat à la livraison.
      </p>
    </div>
    <div class="features-grid">
      <div class="feat-card">
        <div class="feat-card-icon">📦</div>
        <h4>Catalogue produits</h4>
        <p>Des milliers de produits classés par catégories avec photos, descriptions et prix clairs.</p>
      </div>
      <div class="feat-card">
        <div class="feat-card-icon">🚚</div>
        <h4>Suivi livraisons</h4>
        <p>Suivez chaque livraison en temps réel avec alertes automatiques à chaque étape.</p>
      </div>
      <div class="feat-card">
        <div class="feat-card-icon">💬</div>
        <h4>Système de feedback</h4>
        <p>Les clients évaluent les produits, les fournisseurs répondent. Transparence totale.</p>
      </div>
      <div class="feat-card">
        <div class="feat-card-icon">🤖</div>
        <h4>Assistance IA</h4>
        <p>Catégorisation intelligente des produits et analyse des risques de livraison.</p>
      </div>
      <div class="feat-card">
        <div class="feat-card-icon">📊</div>
        <h4>Tableau de bord</h4>
        <p>Statistiques en temps réel adaptées au rôle de chaque utilisateur.</p>
      </div>
      <div class="feat-card">
        <div class="feat-card-icon">🔒</div>
        <h4>Sécurité &amp; Confiance</h4>
        <p>Authentification sécurisée, comptes vérifiés et données personnelles protégées.</p>
      </div>
    </div>
  </div>
</section>

{# ════════════════════════════════════════
   CTA BANNER
   ════════════════════════════════════════ #}
<section class="cta-banner">
  <h2>Prêt à rejoindre la marketplace ?</h2>
  <p>
    Créez votre compte gratuitement en moins de 2 minutes et commencez
    à acheter ou vendre dès aujourd'hui.
  </p>
  <div class="cta-btns">
    <a href="{{ path('app_register') }}" class="btn-cta-white">Créer mon compte →</a>
    <a href="{{ path('app_login') }}"   class="btn-cta-outline">Se connecter</a>
  </div>
</section>

{# ════════════════════════════════════════
   FOOTER
   ════════════════════════════════════════ #}
<footer>
  <div class="footer-inner">
    <div class="footer-top">
      <div class="footer-brand">
        <div class="logo">🛒 <span>Market</span>Place</div>
        <p>La marketplace de confiance pour acheter et vendre en Tunisie.</p>
      </div>
      <div class="footer-links-group">
        <h5>Navigation</h5>
        <a href="{{ path('app_produit_index') }}">Produits</a>
        <a href="#roles">Nos rôles</a>
      </div>
      <div class="footer-links-group">
        <h5>Compte</h5>
        <a href="{{ path('app_login') }}">Se connecter</a>
        <a href="{{ path('app_register') }}">Créer un compte</a>
        <a href="{{ path('app_forgot_password') }}">Mot de passe oublié</a>
      </div>
    </div>
    <p class="copy">© {{ "now"|date("Y") }} MarketPlace — Tous droits réservés</p>
  </div>
</footer>

<script>
document.querySelectorAll('a[href="#roles"]').forEach(a => {
  a.addEventListener('click', e => {
    e.preventDefault();
    document.getElementById('roles').scrollIntoView({ behavior: 'smooth' });
  });
});
</script>
</body>
</html>