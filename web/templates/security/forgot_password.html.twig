{% extends 'base.html.twig' %}

{% block title %}Mot de passe oublié{% endblock %}

{% block auth_content %}
<style>
.fp-card {
    max-width: 480px;
    margin: 0 auto;
    background: #fff;
    border-radius: 20px;
    padding: 2.5rem 2rem;
    box-shadow: 0 8px 40px rgba(0,0,0,0.10);
}
.fp-icon-wrap {
    width: 72px; height: 72px;
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    margin: 0 auto 1.2rem;
    font-size: 2rem;
}
.fp-icon-wrap.orange { background: #fff3e8; }
.fp-icon-wrap.green  { background: #e8faf2; }
.fp-divider {
    display: flex; align-items: center; gap: 12px;
    margin: 1.4rem 0;
    color: #94a3b8; font-size: .85rem;
}
.fp-divider::before, .fp-divider::after {
    content:''; flex:1; height:1px; background:#e2e8f0;
}
.fp-input-group {
    display: flex;
    border: 1.5px solid #e2e8f0;
    border-radius: 12px;
    overflow: hidden;
    transition: border-color .2s;
    background: #f8fafc;
}
.fp-input-group:focus-within {
    border-color: #f97316;
    background: #fff;
    box-shadow: 0 0 0 3px rgba(249,115,22,.10);
}
.fp-input-group.green:focus-within {
    border-color: #10b981;
    box-shadow: 0 0 0 3px rgba(16,185,129,.10);
}
.fp-input-group .prefix {
    padding: 0 14px;
    background: #f1f5f9;
    display: flex; align-items: center;
    color: #64748b; font-size: .9rem; font-weight: 600;
    border-right: 1.5px solid #e2e8f0;
    white-space: nowrap;
}
.fp-input-group input {
    border: none; background: transparent;
    padding: 13px 14px; flex: 1;
    font-size: 1rem; outline: none; color: #1e293b;
}
.fp-input-group input::placeholder { color: #94a3b8; }
.fp-label {
    font-weight: 600; font-size: .9rem;
    color: #374151; margin-bottom: .5rem; display: block;
}
.btn-send-email {
    width: 100%;
    background: #1e3a5f;
    color: #fff;
    border: 2px solid #f97316;
    border-radius: 12px;
    padding: 13px;
    font-size: 1rem; font-weight: 600;
    cursor: pointer; transition: all .2s;
    display: flex; align-items: center; justify-content: center; gap: 8px;
}
.btn-send-email:hover { background: #162d4a; }
.btn-send-sms {
    width: 100%;
    background: #e8faf2;
    color: #059669;
    border: 2px solid #10b981;
    border-radius: 12px;
    padding: 13px;
    font-size: 1rem; font-weight: 600;
    cursor: pointer; transition: all .2s;
    display: flex; align-items: center; justify-content: center; gap: 8px;
}
.btn-send-sms:hover { background: #d1fae5; }
.fp-back {
    text-align: center; margin-top: 1.2rem;
    font-size: .9rem; color: #94a3b8;
}
.fp-back a { color: #64748b; text-decoration: none; font-weight: 500; }
.fp-back a:hover { color: #1e293b; }
.invalid-msg { color: #ef4444; font-size: .82rem; margin-top: .3rem; }
.fp-title { font-weight: 800; font-size: 1.55rem; text-align: center; color: #1e293b; margin-bottom: .3rem; }
.fp-sub { text-align: center; color: #64748b; font-size: .93rem; margin-bottom: 1.4rem; }
.fp-sep { border: none; border-top: 2px solid #f97316; margin: 1.2rem 0 1.5rem; opacity:.5; }
</style>

<div class="auth-container">
<div class="fp-card">

    <div class="fp-icon-wrap orange">🔑</div>
    <div class="fp-title">Mot de passe oublié ?</div>
    <p class="fp-sub">Entrez votre email ou téléphone pour recevoir un code OTP</p>
    <hr class="fp-sep">

    {% for flash in app.flashes('error') %}
        <div class="alert alert-danger mb-3">{{ flash }}</div>
    {% endfor %}

    {# ── FORM 1 : Email ── #}
    <form method="post" action="{{ path('app_forgot_password') }}" novalidate>
        <input type="hidden" name="channel" value="email">

        <label class="fp-label" for="email_identifier">Adresse email</label>
        <div class="fp-input-group">
            <span class="prefix"><i class="bi bi-envelope-fill" style="color:#f97316;"></i></span>
            <input type="email" name="identifier" id="email_identifier"
                   placeholder="vous@gmail.com"
                   value="{{ channel == 'email' ? identifier : '' }}"
                   autocomplete="email">
        </div>
        {% if channel == 'email' and errors.identifier is defined %}
            <div class="invalid-msg">{{ errors.identifier }}</div>
        {% endif %}
        {% if channel == 'email' and errors.delivery is defined %}
            <div class="invalid-msg">{{ errors.delivery }}</div>
        {% endif %}

        <div style="margin-top:1rem;">
            <button type="submit" class="btn-send-email">
                <i class="bi bi-envelope-fill"></i> Envoyer le code par email
            </button>
        </div>
    </form>

    <div class="fp-divider">OU</div>

    {# ── FORM 2 : SMS ── #}
    <form method="post" action="{{ path('app_forgot_password') }}" novalidate>
        <input type="hidden" name="channel" value="sms">

        <label class="fp-label" for="phone_identifier">Numéro de téléphone</label>
        <div class="fp-input-group green">
            <span class="prefix">+216</span>
            <input type="tel" name="identifier" id="phone_identifier"
                   placeholder="XX XXX XXX"
                   value="{{ channel == 'sms' ? identifier : '' }}"
                   autocomplete="tel" maxlength="15">
        </div>
        {% if channel == 'sms' and errors.identifier is defined %}
            <div class="invalid-msg">{{ errors.identifier }}</div>
        {% endif %}
        {% if channel == 'sms' and errors.delivery is defined %}
            <div class="invalid-msg">{{ errors.delivery }}</div>
        {% endif %}

        <div style="margin-top:1rem;">
            <button type="submit" class="btn-send-sms">
                <i class="bi bi-phone-fill"></i> Envoyer le code par SMS &nbsp;(Twilio)
            </button>
        </div>
    </form>

    <div class="fp-back">
        <a href="{{ path('app_login') }}">← Retour à la connexion</a>
    </div>

</div>
</div>
{% endblock %}