{% extends 'base.html.twig' %}

{% block title %}Vérifier le code{% endblock %}

{% block auth_content %}
<style>
.vc-card {
    max-width: 460px;
    margin: 0 auto;
    background: #fff;
    border-radius: 20px;
    padding: 2.5rem 2rem;
    box-shadow: 0 8px 40px rgba(0,0,0,0.10);
}
.vc-icon-wrap {
    width: 72px; height: 72px;
    border-radius: 50%;
    background: #fff8ed;
    display: flex; align-items: center; justify-content: center;
    margin: 0 auto 1.1rem;
    font-size: 2rem;
}
.vc-title { font-weight: 800; font-size: 1.4rem; text-align:center; color:#1e293b; margin-bottom:.3rem; }
.vc-step  { font-weight: 700; font-size:.78rem; letter-spacing:.1em; text-transform:uppercase; color:#f97316; text-align:center; margin-bottom:.2rem; }
.vc-sub   { text-align:center; color:#64748b; font-size:.9rem; margin-bottom:1.4rem; }
.vc-sub strong { color:#1e293b; }
.vc-sep   { border:none; border-top:2px solid #f97316; margin:0 0 1.5rem; opacity:.4; }

/* OTP boxes */
.otp-wrap {
    display: flex; gap: 10px; justify-content: center; margin-bottom:.4rem;
}
.otp-wrap input {
    width: 52px; height: 60px;
    border: 2px solid #e2e8f0;
    border-radius: 12px;
    text-align: center;
    font-size: 1.6rem; font-weight: 700; color: #1e293b;
    background: #f8fafc;
    outline: none; transition: all .2s;
    caret-color: #f97316;
}
.otp-wrap input:focus {
    border-color: #f97316;
    background: #fff;
    box-shadow: 0 0 0 3px rgba(249,115,22,.12);
}
.otp-wrap input.is-invalid { border-color:#ef4444; }
.otp-hidden { display:none; }
.vc-expire { text-align:center; font-size:.82rem; color:#94a3b8; margin-bottom:.2rem; }
.vc-resend { text-align:right; font-size:.83rem; }
.vc-resend a { color:#f97316; text-decoration:none; font-weight:600; }
.vc-resend a:hover { text-decoration:underline; }
.invalid-msg { color:#ef4444; font-size:.82rem; text-align:center; margin-top:.2rem; }

.btn-verify {
    width:100%; margin-top:1.4rem;
    background:#f97316; color:#fff;
    border:none; border-radius:12px;
    padding:14px; font-size:1rem; font-weight:700;
    cursor:pointer; transition:background .2s;
    display:flex; align-items:center; justify-content:center; gap:8px;
}
.btn-verify:hover { background:#ea6c0a; }
.vc-back { text-align:center; margin-top:1.1rem; font-size:.88rem; color:#94a3b8; }
.vc-back a { color:#64748b; text-decoration:none; font-weight:500; }
.vc-back a:hover { color:#1e293b; }
</style>

<div class="auth-container">
<div class="vc-card">

    <div class="vc-icon-wrap">📩</div>
    <div class="vc-step">Étape 2 — Vérification</div>
    <div class="vc-title">Entrez le code reçu</div>
    <p class="vc-sub">
        Code envoyé par <strong>{{ channel == 'sms' ? 'SMS' : 'email' }}</strong>
        à <strong>{{ maskedTarget }}</strong>
    </p>
    <hr class="vc-sep">

    <form method="post" novalidate id="otpForm">

        {# Hidden real input sent to server #}
        <input type="hidden" name="code" id="realCode" value="{{ code ?? '' }}">

        {# 6 visible digit boxes #}
        <div class="otp-wrap" id="otpBoxes">
            {% for i in 1..6 %}
            <input type="text" inputmode="numeric" maxlength="1"
                   class="otp-box {% if errors.code is defined %}is-invalid{% endif %}"
                   autocomplete="one-time-code">
            {% endfor %}
        </div>

        {% if errors.code is defined %}
            <div class="invalid-msg">{{ errors.code }}</div>
        {% endif %}

        <div class="vc-expire">Expire dans 15 minutes</div>
        <div class="vc-resend">
            <a href="{{ path('app_forgot_password') }}">Renvoyer</a>
        </div>

        <button type="submit" class="btn-verify">
            <i class="bi bi-check-circle-fill"></i> Vérifier le code
        </button>
    </form>

    <div class="vc-back">
        <a href="{{ path('app_forgot_password') }}">← Recommencer</a>
    </div>

</div>
</div>

<script>
(function () {
    const boxes  = Array.from(document.querySelectorAll('.otp-box'));
    const hidden = document.getElementById('realCode');

    // Pre-fill if value exists (e.g. after error)
    const pre = hidden.value.replace(/\D/g, '');
    if (pre) {
        [...pre].forEach((ch, i) => { if (boxes[i]) boxes[i].value = ch; });
    }

    function sync() {
        hidden.value = boxes.map(b => b.value).join('');
    }

    boxes.forEach((box, idx) => {
        box.addEventListener('input', e => {
            const val = e.target.value.replace(/\D/g, '');
            box.value = val ? val[val.length - 1] : '';
            sync();
            if (val && idx < 5) boxes[idx + 1].focus();
        });

        box.addEventListener('keydown', e => {
            if (e.key === 'Backspace' && !box.value && idx > 0) {
                boxes[idx - 1].focus();
                boxes[idx - 1].value = '';
                sync();
            }
        });

        box.addEventListener('paste', e => {
            e.preventDefault();
            const pasted = (e.clipboardData || window.clipboardData)
                .getData('text').replace(/\D/g, '').slice(0, 6);
            [...pasted].forEach((ch, i) => { if (boxes[i]) boxes[i].value = ch; });
            const next = Math.min(pasted.length, 5);
            boxes[next].focus();
            sync();
        });
    });

    // Auto-focus first empty box
    const firstEmpty = boxes.find(b => !b.value);
    if (firstEmpty) firstEmpty.focus();
})();
</script>
{% endblock %}